<% content_for :title, t(".title") %>

<main class="flex flex-1 flex-col gap-8 py-8">
  <header class="flex flex-col gap-5 border-b border-stone-200 pb-6 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="text-sm font-semibold text-emerald-800"><%= t(".kicker") %></p>
      <h1 class="mt-3 text-3xl font-semibold text-stone-950"><%= t(".heading") %></h1>
      <p class="mt-3 max-w-3xl text-base leading-7 text-stone-700"><%= t(".body") %></p>
    </div>

    <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-950">
      <%= t(".admin_only") %>
    </div>
  </header>

  <section aria-labelledby="feature-flags-heading" class="overflow-hidden rounded-xl border border-stone-200 bg-white">
    <div class="flex flex-col gap-2 border-b border-stone-200 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 id="feature-flags-heading" class="text-base font-semibold text-stone-950"><%= t(".flags_title") %></h2>
        <p class="mt-1 text-sm text-stone-700"><%= t(".flags_body") %></p>
      </div>
      <span class="text-sm font-medium text-stone-700"><%= t(".flags_count", count: @feature_flags.size) %></span>
    </div>

    <% if @feature_flags.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-stone-200 text-left text-sm">
          <thead class="bg-stone-50 text-xs font-semibold uppercase text-stone-600">
            <tr>
              <th scope="col" class="px-5 py-3"><%= t(".flag") %></th>
              <th scope="col" class="px-5 py-3"><%= t(".state") %></th>
              <th scope="col" class="px-5 py-3"><%= t(".assignments") %></th>
              <th scope="col" class="px-5 py-3"><%= t(".cleanup") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-stone-200">
            <% @feature_flags.each do |flag| %>
              <tr>
                <th scope="row" class="px-5 py-4 align-top">
                  <span class="block font-semibold text-stone-950"><%= flag.name %></span>
                  <span class="mt-1 block font-mono text-xs text-stone-600"><%= flag.key %></span>
                  <% if flag.description.present? %>
                    <span class="mt-2 block max-w-xl text-sm font-normal leading-6 text-stone-700"><%= flag.description %></span>
                  <% end %>
                </th>
                <td class="px-5 py-4 align-top">
                  <% state_key = flag.retired? ? "retired" : (flag.enabled? ? "enabled" : "disabled") %>
                  <% state_classes = flag.retired? ? "border-amber-200 bg-amber-50 text-amber-950" : (flag.enabled? ? "border-emerald-200 bg-emerald-50 text-emerald-950" : "border-stone-200 bg-stone-50 text-stone-700") %>
                  <span class="inline-flex rounded-full border px-2.5 py-1 text-xs font-semibold <%= state_classes %>">
                    <%= t(".states.#{state_key}") %>
                  </span>
                </td>
                <td class="px-5 py-4 align-top text-stone-700">
                  <%= t(".assignment_count", count: flag.feature_flag_assignments.size) %>
                </td>
                <td class="px-5 py-4 align-top text-stone-700">
                  <%= flag.retired? ? t(".retired_at", date: l(flag.retired_at.to_date)) : t(".not_retired") %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-5 py-10">
        <h3 class="text-base font-semibold text-stone-950"><%= t(".empty_title") %></h3>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-stone-700"><%= t(".empty_body") %></p>
      </div>
    <% end %>
  </section>

  <section aria-labelledby="rollout-groups-heading" class="rounded-xl border border-stone-200 bg-white p-5">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 id="rollout-groups-heading" class="text-base font-semibold text-stone-950"><%= t(".rollout_groups_title") %></h2>
        <p class="mt-1 text-sm leading-6 text-stone-700"><%= t(".rollout_groups_body") %></p>
      </div>
      <span class="text-sm font-medium text-stone-700"><%= t(".rollout_groups_count", count: @rollout_groups.size) %></span>
    </div>

    <% if @rollout_groups.any? %>
      <ul class="mt-5 grid gap-3 md:grid-cols-2">
        <% @rollout_groups.each do |group| %>
          <li class="rounded-lg border border-stone-200 bg-stone-50 p-4">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <h3 class="font-semibold text-stone-950"><%= group.name %></h3>
                <p class="mt-1 font-mono text-xs text-stone-600"><%= group.key %></p>
              </div>
              <% if group.retired? %>
                <span class="inline-flex rounded-full border border-amber-200 bg-amber-50 px-2.5 py-1 text-xs font-semibold text-amber-950"><%= t(".states.retired") %></span>
              <% end %>
            </div>
            <% if group.description.present? %>
              <p class="mt-3 text-sm leading-6 text-stone-700"><%= group.description %></p>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="mt-5 text-sm leading-6 text-stone-700"><%= t(".rollout_groups_empty") %></p>
    <% end %>
  </section>
</main>
