<%= turbo_frame_tag "commitments_section" do %>
  <% commitments = relationship_profile.commitments.to_a.sort_by { |commitment| [ commitment.open? ? 0 : commitment.completed? ? 1 : 2, commitment.due_on || Date.new(9999, 12, 31), commitment.title.downcase, commitment.id.to_s ] } %>
  <% open_commitments = commitments.select(&:open?) %>
  <% overdue_count = open_commitments.count(&:overdue?) %>

  <section class="rounded-2xl border border-stone-200 bg-white p-5 shadow-sm shadow-stone-200/40">
    <div class="flex flex-col gap-4 border-b border-stone-200 pb-5 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <p class="text-sm font-semibold text-emerald-800"><%= t("commitments.section.kicker") %></p>
        <h2 class="mt-2 text-xl font-semibold text-stone-950"><%= t("commitments.section.title") %></h2>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-stone-700"><%= t("commitments.section.body") %></p>
      </div>
      <%= link_to t("commitments.form.create"), new_relationship_profile_commitment_path(relationship_profile, timeline_type: selected_type), data: { turbo_frame: "new_commitment" }, class: "inline-flex min-h-11 w-fit items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    </div>

    <%= turbo_frame_tag "new_commitment", class: "block mt-5" %>

    <div class="mt-5 grid gap-5 xl:grid-cols-[minmax(0,1fr)_18rem]">
      <div class="rounded-xl border border-stone-200 bg-stone-50/70 p-4">
        <div class="flex items-center justify-between gap-3">
          <h3 class="text-base font-semibold text-stone-950"><%= t("commitments.section.list_title") %></h3>
          <span class="text-xs font-medium text-stone-600"><%= t("commitments.section.commitment_count", count: commitments.size) %></span>
        </div>
        <% if commitments.any? %>
          <div class="mt-4 grid gap-3"><% commitments.each do |commitment| %><%= render "commitments/commitment", relationship_profile:, commitment:, selected_type: %><% end %></div>
        <% else %>
          <div class="mt-4 rounded-lg border border-dashed border-stone-300 bg-white px-4 py-5">
            <p class="text-sm font-semibold text-stone-950"><%= t("commitments.section.empty_title") %></p>
            <p class="mt-2 text-sm leading-6 text-stone-700"><%= t("commitments.section.empty_body") %></p>
          </div>
        <% end %>
      </div>

      <aside class="rounded-xl border border-emerald-200 bg-emerald-50/70 p-4">
        <h3 class="text-base font-semibold text-stone-950"><%= t("commitments.section.summary_title") %></h3>
        <dl class="mt-4 grid gap-3 text-sm">
          <div><dt class="font-semibold text-stone-800"><%= t("commitments.section.open_label") %></dt><dd class="mt-1 text-stone-700"><%= t("commitments.section.open_count", count: open_commitments.size) %></dd></div>
          <div><dt class="font-semibold text-stone-800"><%= t("commitments.section.overdue_label") %></dt><dd class="mt-1 <%= overdue_count.positive? ? "text-red-700" : "text-stone-700" %>"><%= t("commitments.section.overdue_count", count: overdue_count) %></dd></div>
        </dl>
        <p class="mt-5 border-t border-emerald-200 pt-4 text-sm leading-6 text-stone-700"><%= t("commitments.section.summary_body") %></p>
      </aside>
    </div>
  </section>
<% end %>
