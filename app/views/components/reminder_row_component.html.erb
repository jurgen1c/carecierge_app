<%= helpers.turbo_frame_tag dom_id(reminder) do %>
  <article data-reminder-row class="<%= style(urgency:, compact:) %>">
    <div class="text-sm text-stone-700">
      <time datetime="<%= delivery_at.iso8601 %>" class="font-semibold <%= urgency == :overdue ? "text-red-800" : "text-stone-950" %>"><%= l(delivery_at, format: :reminder_day) %></time>
      <p class="mt-1 text-xs font-medium"><%= l(delivery_at, format: :reminder_time) %></p>
    </div>

    <div class="relative pl-6">
      <span class="<%= style(:dot, urgency:) %>" aria-hidden="true"></span>
      <div class="flex flex-wrap items-center gap-2">
        <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-900"><%= reminder.reminder_type_label %></span>
        <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-stone-700"><%= reminder.priority_label %></span>
        <span class="rounded-full border border-stone-200 bg-white px-3 py-1 text-xs font-medium text-stone-700"><%= reminder.recurrence_label %></span>
      </div>
      <h4 class="mt-3 text-base font-semibold text-stone-950"><%= reminder.title %></h4>
      <% if relationship_name.present? || reminder.important_date.present? %>
        <p class="mt-1 text-sm text-stone-700">
          <%= [relationship_name, reminder.important_date&.display_title].compact.join(" · ") %>
        </p>
      <% end %>
      <% if reminder.notes.present? %>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-stone-700"><%= reminder.notes %></p>
      <% end %>
    </div>

    <% unless compact %>
      <div class="flex shrink-0 flex-wrap items-start gap-2 sm:justify-end">
        <%= button_to t("reminders.actions.complete"), complete_reminder_path(reminder), method: :patch, class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-emerald-700 bg-white px-4 py-2 text-sm font-semibold text-emerald-900 transition hover:bg-emerald-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        <%= button_to t("reminders.actions.snooze"), snooze_reminder_path(reminder), method: :patch, params: { snooze_for: "one_hour" }, class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-stone-300 bg-white px-4 py-2 text-sm font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        <%= link_to t("reminders.actions.export"), calendar_reminder_path(reminder, format: :ics), class: "inline-flex min-h-11 items-center justify-center rounded-lg px-3 py-2 text-sm font-semibold text-stone-700 hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        <%= link_to t("reminders.actions.edit"), edit_reminder_path(reminder), data: { turbo_frame: dom_id(reminder) }, class: "inline-flex min-h-11 items-center justify-center rounded-lg px-3 py-2 text-sm font-semibold text-stone-700 hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
      </div>
    <% end %>
  </article>
<% end %>
