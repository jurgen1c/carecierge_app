<%= turbo_frame_tag "contact_rhythm_section" do %>
  <% cadence = relationship_profile.contact_cadence %>
  <% suggestion = ContactCadence.suggested_interval_days_for(relationship_profile) %>

  <section class="rounded-2xl border border-stone-200 bg-white p-5 shadow-sm shadow-stone-200/40">
    <div class="flex flex-col gap-4 border-b border-stone-200 pb-5 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="text-sm font-semibold text-emerald-800"><%= t("contact_rhythm.section.kicker") %></p>
        <h2 class="mt-2 text-xl font-semibold text-stone-950"><%= t("contact_rhythm.section.title") %></h2>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-stone-700"><%= t("contact_rhythm.section.body") %></p>
      </div>

      <%= link_to t("contact_rhythm.interactions.log"),
        new_relationship_profile_interaction_path(relationship_profile),
        data: { turbo_frame: "new_interaction" },
        class: "inline-flex min-h-11 shrink-0 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    </div>

    <div class="mt-5 grid gap-6 xl:grid-cols-[minmax(0,1.45fr)_minmax(18rem,0.55fr)]">
      <div class="min-w-0">
        <div class="flex items-center justify-between gap-3">
          <h3 class="text-base font-semibold text-stone-950"><%= t("contact_rhythm.interactions.title") %></h3>
          <span class="text-xs font-medium text-stone-600"><%= t("contact_rhythm.interactions.shown", count: interactions.size) %></span>
        </div>

        <% if interactions.any? %>
          <div class="mt-3 divide-y divide-stone-200 border-y border-stone-200">
            <% interactions.each do |interaction| %>
              <%= render "interactions/interaction", relationship_profile:, interaction: %>
            <% end %>
          </div>
        <% else %>
          <div class="mt-4 rounded-xl border border-dashed border-stone-300 bg-stone-50 px-5 py-6">
            <p class="text-sm font-semibold text-stone-950"><%= t("contact_rhythm.interactions.empty_title") %></p>
            <p class="mt-2 max-w-2xl text-sm leading-6 text-stone-700"><%= t("contact_rhythm.interactions.empty_body") %></p>
            <%= link_to t("contact_rhythm.interactions.log_first"),
              new_relationship_profile_interaction_path(relationship_profile),
              data: { turbo_frame: "new_interaction" },
              class: "mt-4 inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
          </div>
        <% end %>

        <%= turbo_frame_tag "new_interaction", src: new_relationship_profile_interaction_path(relationship_profile), loading: :lazy do %>
          <span class="sr-only"><%= t("contact_rhythm.interactions.form_loading") %></span>
        <% end %>
      </div>

      <aside class="grid content-start gap-4">
        <section class="rounded-xl border border-stone-200 bg-stone-50 p-4">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-sm font-semibold text-stone-950"><%= t("contact_rhythm.cadence.title") %></h3>
              <% if cadence %>
                <p class="mt-2 text-2xl font-semibold text-stone-950"><%= t("contact_rhythm.intervals.#{cadence.interval_days}") %></p>
              <% else %>
                <p class="mt-2 text-2xl font-semibold text-stone-950"><%= t("contact_rhythm.intervals.#{suggestion}") %></p>
                <p class="mt-1 text-sm leading-6 text-stone-700"><%= t("contact_rhythm.cadence.suggested_for", relationship_type: relationship_profile.relationship_type_label) %></p>
              <% end %>
            </div>
            <span class="mt-1 size-7 rounded-full border-[3px] border-emerald-700 border-r-transparent" aria-hidden="true"></span>
          </div>

          <% if cadence %>
            <dl class="mt-4 border-t border-stone-200 pt-4 text-sm">
              <dt class="font-medium text-stone-700"><%= t("contact_rhythm.cadence.next_window") %></dt>
              <dd class="mt-1 font-semibold text-stone-950"><%= l(cadence.next_check_in_at, format: :interaction_day) %></dd>
              <% if cadence.last_interaction_at %>
                <dt class="mt-3 font-medium text-stone-700"><%= t("contact_rhythm.cadence.last_interaction") %></dt>
                <dd class="mt-1 text-stone-950"><%= l(cadence.last_interaction_at, format: :interaction_day) %></dd>
              <% end %>
            </dl>
          <% else %>
            <p class="mt-4 border-t border-stone-200 pt-4 text-sm leading-6 text-stone-700"><%= t("contact_rhythm.cadence.suggestion_body") %></p>
          <% end %>

          <%= turbo_frame_tag "contact_cadence_form", src: cadence ? edit_relationship_profile_contact_cadence_path(relationship_profile) : new_relationship_profile_contact_cadence_path(relationship_profile), loading: :lazy do %>
            <%= link_to cadence ? t("contact_rhythm.cadence.adjust") : t("contact_rhythm.cadence.use_suggestion"),
              cadence ? edit_relationship_profile_contact_cadence_path(relationship_profile) : new_relationship_profile_contact_cadence_path(relationship_profile),
              class: "mt-4 inline-flex min-h-11 w-full items-center justify-center rounded-lg border border-emerald-700 bg-white px-4 py-2 text-sm font-semibold text-emerald-800 transition hover:bg-emerald-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
          <% end %>
        </section>

        <% if cadence&.overdue? %>
          <section class="rounded-xl border border-orange-200 bg-orange-50 p-4">
            <h3 class="text-sm font-semibold text-stone-950"><%= t("contact_rhythm.overdue.title") %></h3>
            <p class="mt-2 text-sm leading-6 text-stone-700"><%= t("contact_rhythm.overdue.body") %></p>
            <div class="mt-4 grid gap-2 sm:grid-cols-2 xl:grid-cols-1">
              <%= link_to t("contact_rhythm.interactions.log"),
                new_relationship_profile_interaction_path(relationship_profile),
                data: { turbo_frame: "new_interaction" },
                class: "inline-flex min-h-11 items-center justify-center rounded-lg bg-orange-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-orange-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-700" %>
              <%= link_to t("contact_rhythm.overdue.plan_reminder"),
                new_reminder_path(relationship_profile_id: relationship_profile.id),
                data: { turbo_frame: "_top" },
                class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-orange-300 bg-white px-4 py-2 text-sm font-semibold text-orange-800 transition hover:bg-orange-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-700" %>
            </div>
          </section>
        <% end %>

        <p class="rounded-xl border border-stone-200 bg-white p-4 text-sm leading-6 text-stone-700"><%= t("contact_rhythm.cadence.flexible_note") %></p>
      </aside>
    </div>
  </section>
<% end %>
