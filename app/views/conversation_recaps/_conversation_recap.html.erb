<% selected_type = local_assigns[:selected_type] %>

<%= turbo_frame_tag dom_id(conversation_recap) do %>
  <article id="<%= dom_id(conversation_recap, :row) %>" class="rounded-lg border border-stone-200 bg-white p-4">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-900"><%= conversation_recap.capture_source_label %></span>
          <span class="rounded-full bg-stone-100 px-3 py-1 text-xs font-semibold text-stone-800"><%= conversation_recap.extraction_status_label %></span>
          <time datetime="<%= conversation_recap.occurred_at.iso8601 %>" class="rounded-full bg-white px-3 py-1 text-xs font-medium text-stone-700 ring-1 ring-inset ring-stone-200"><%= l(conversation_recap.occurred_at, format: :timeline_entry_day) %></time>
        </div>
        <h4 class="mt-3 text-sm font-semibold text-stone-950"><%= conversation_recap.title %></h4>
        <p class="mt-1 whitespace-pre-line text-sm leading-6 text-stone-700"><%= conversation_recap.body %></p>
        <% if conversation_recap.transcript.present? %>
          <details class="mt-3 rounded-lg border border-stone-200 bg-stone-50 px-3 py-2">
            <summary class="cursor-pointer text-xs font-semibold text-stone-800"><%= t("conversation_recaps.recap.transcript") %></summary>
            <p class="mt-2 whitespace-pre-line text-sm leading-6 text-stone-700"><%= conversation_recap.transcript %></p>
          </details>
        <% end %>
      </div>

      <div class="flex shrink-0 flex-wrap gap-2">
        <%= link_to t("conversation_recaps.recap.edit"), edit_relationship_profile_conversation_recap_path(relationship_profile, conversation_recap, timeline_type: selected_type), class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-stone-300 bg-white px-3 py-2 text-xs font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        <%= button_to t("conversation_recaps.recap.delete"), relationship_profile_conversation_recap_path(relationship_profile, conversation_recap, timeline_type: selected_type), method: :delete, form: { data: { turbo_confirm: t("conversation_recaps.recap.delete_confirm") } }, class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-red-200 bg-white px-3 py-2 text-xs font-semibold text-red-800 transition hover:bg-red-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-700" %>
      </div>
    </div>

    <div class="mt-4 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2">
      <p class="text-sm font-semibold text-amber-950"><%= t("conversation_recaps.recap.approval_title") %></p>
      <p class="mt-1 text-sm leading-6 text-amber-900"><%= t("conversation_recaps.recap.approval_body") %></p>
    </div>
  </article>
<% end %>
