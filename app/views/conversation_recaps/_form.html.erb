<% selected_type = local_assigns[:selected_type] %>
<% form_url = conversation_recap.persisted? ? relationship_profile_conversation_recap_path(relationship_profile, conversation_recap, timeline_type: selected_type) : relationship_profile_conversation_recaps_path(relationship_profile, timeline_type: selected_type) %>

<%= form_with model: conversation_recap, url: form_url, method: conversation_recap.persisted? ? :patch : :post, class: "rounded-xl border border-stone-200 bg-white p-4" do |form| %>
  <div>
    <h3 class="text-base font-semibold text-stone-950"><%= conversation_recap.persisted? ? t("conversation_recaps.form.edit_title") : t("conversation_recaps.form.new_title") %></h3>
    <p class="mt-1 text-sm leading-6 text-stone-700"><%= t("conversation_recaps.form.body") %></p>
  </div>

  <% if conversation_recap.errors.any? %>
    <div class="mt-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-950">
      <p class="font-semibold"><%= t("conversation_recaps.form.errors_heading", count: conversation_recap.errors.count) %></p>
      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% conversation_recap.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mt-4 grid gap-4 sm:grid-cols-2">
    <div class="sm:col-span-2">
      <%= form.label :title, t("conversation_recaps.form.title"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.text_field :title, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20", placeholder: t("conversation_recaps.form.title_placeholder") %>
    </div>

    <div>
      <%= form.label :occurred_at, t("conversation_recaps.form.occurred_at"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.datetime_local_field :occurred_at, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>

    <div>
      <%= form.label :capture_source, t("conversation_recaps.form.capture_source"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.select :capture_source, ConversationRecap.capture_source_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>
  </div>

  <div class="mt-4">
    <%= form.label :body, t("conversation_recaps.form.recap"), class: "block text-sm font-medium text-stone-800" %>
    <%= form.text_area :body, rows: 5, class: "mt-2 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20", placeholder: t("conversation_recaps.form.recap_placeholder") %>
  </div>

  <div class="mt-4">
    <%= form.label :transcript, t("conversation_recaps.form.transcript"), class: "block text-sm font-medium text-stone-800" %>
    <%= form.text_area :transcript, rows: 3, class: "mt-2 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20", placeholder: t("conversation_recaps.form.transcript_placeholder") %>
  </div>

  <% unless conversation_recap.persisted? || conversation_recap.extraction_status != "not_requested" %>
    <div class="mt-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
      <div class="flex gap-3">
        <%= form.check_box :request_memory_extraction, class: "mt-1 size-5 rounded border-amber-300 text-emerald-800 focus:ring-emerald-700" %>
        <div>
          <%= form.label :request_memory_extraction, t("conversation_recaps.form.request_extraction"), class: "text-sm font-semibold text-amber-950" %>
          <p class="mt-1 text-sm leading-6 text-amber-900"><%= t("conversation_recaps.form.request_extraction_body") %></p>
        </div>
      </div>
    </div>
  <% end %>

  <div class="mt-4 flex flex-wrap items-center gap-3">
    <%= form.submit conversation_recap.persisted? ? t("conversation_recaps.form.update") : t("conversation_recaps.form.create"), class: "inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <% if conversation_recap.persisted? %>
      <%= link_to t("conversation_recaps.form.cancel"), relationship_profile_path(relationship_profile, timeline_type: selected_type, anchor: dom_id(conversation_recap, :row)), data: { turbo_frame: "_top" }, class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <% end %>
  </div>
<% end %>
