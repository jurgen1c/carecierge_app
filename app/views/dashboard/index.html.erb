<% content_for :title, t(".title") %>

<main class="flex flex-1 flex-col gap-8 py-8">
  <header class="flex flex-col gap-5 border-b border-stone-200 pb-6 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-sm font-semibold text-emerald-800"><%= t(".kicker") %></p>
      <h1 class="mt-3 text-3xl font-semibold text-stone-950"><%= t(".heading") %></h1>
      <p class="mt-3 max-w-2xl text-base leading-7 text-stone-700"><%= t(".body") %></p>
      <% if @onboarding_available %>
        <div class="mt-5 flex flex-wrap gap-3">
          <%= link_to t(".continue_onboarding"), onboarding_path, class: "inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        </div>
      <% end %>
    </div>

    <%= button_to t(".sign_out"), destroy_user_session_path, method: :delete, class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition hover:border-stone-400 hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
  </header>

  <section class="grid gap-4 md:grid-cols-3">
    <article class="rounded-xl border border-stone-200 bg-white p-5">
      <h2 class="text-base font-semibold text-stone-950"><%= t(".relationship_profile_title") %></h2>
      <p class="mt-3 text-sm leading-6 text-stone-700"><%= t(".relationship_profile_body") %></p>
      <%= link_to t(".relationship_profile_action"), relationship_profiles_path, class: "mt-5 inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    </article>
    <article class="rounded-xl border border-stone-200 bg-white p-5">
      <h2 class="text-base font-semibold text-stone-950"><%= t(".important_dates_title") %></h2>
      <p class="mt-3 text-sm leading-6 text-stone-700"><%= t(".important_dates_body") %></p>
      <%= link_to t(".reminders_action"), reminders_path, class: "mt-5 inline-flex min-h-11 items-center justify-center rounded-lg border border-emerald-700 bg-white px-5 py-3 text-sm font-semibold text-emerald-900 transition hover:bg-emerald-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    </article>
    <article class="rounded-xl border border-stone-200 bg-white p-5">
      <h2 class="text-base font-semibold text-stone-950"><%= t(".privacy_title") %></h2>
      <p class="mt-3 text-sm leading-6 text-stone-700"><%= t(".privacy_body") %></p>
    </article>
  </section>
</main>
