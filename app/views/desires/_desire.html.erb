<%= turbo_frame_tag dom_id(desire) do %>
  <% ordered_fulfillments = desire.fulfillments.to_a.sort_by { |fulfillment| [ fulfillment.fulfilled_on, fulfillment.created_at ] }.reverse %>
  <% captured_on_label = desire.captured_on.present? ? l(desire.captured_on, format: :desire_captured_on) : t("desires.item.captured_on_unknown") %>

  <article id="<%= dom_id(desire, :row) %>" class="rounded-lg border border-stone-200 bg-white p-4">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-900"><%= desire.category_label %></span>
          <span class="rounded-full bg-stone-100 px-3 py-1 text-xs font-medium text-stone-700"><%= desire.status_label %></span>
          <span class="rounded-full border border-stone-200 bg-white px-3 py-1 text-xs font-medium text-stone-700"><%= desire.source_label %></span>
        </div>

        <h4 class="mt-3 text-base font-semibold text-stone-950"><%= desire.title %></h4>
        <% if desire.notes.present? %>
          <p class="mt-2 text-sm leading-6 text-stone-700"><%= desire.notes %></p>
        <% end %>
        <dl class="mt-3 grid gap-2 text-sm text-stone-700 sm:grid-cols-2">
          <div>
            <dt class="font-medium text-stone-800"><%= t("desires.item.captured_on") %></dt>
            <dd class="mt-1"><%= captured_on_label %></dd>
          </div>
          <div>
            <dt class="font-medium text-stone-800"><%= t("desires.item.feeds") %></dt>
            <dd class="mt-1"><%= desire.suggestion_context_labels.to_sentence %></dd>
          </div>
        </dl>

        <% if ordered_fulfillments.any? %>
          <div class="mt-4 rounded-lg border border-stone-200 bg-stone-50 px-4 py-3">
            <p class="text-sm font-semibold text-stone-950"><%= t("desires.item.fulfillment_history") %></p>
            <div class="mt-3 grid gap-3">
              <% ordered_fulfillments.each do |fulfillment| %>
                <div>
                  <p class="text-sm font-medium text-stone-900"><%= l(fulfillment.fulfilled_on, format: :desire_captured_on) %></p>
                  <% if fulfillment.notes.present? %>
                    <p class="mt-1 text-sm leading-6 text-stone-700"><%= fulfillment.notes %></p>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="flex shrink-0 flex-wrap gap-2">
        <%= link_to t("desires.item.edit"), edit_relationship_profile_desire_path(relationship_profile, desire), class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-stone-300 bg-white px-4 py-2 text-sm font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        <% unless desire.fulfilled? %>
          <%= button_to t("desires.item.fulfill"), fulfill_relationship_profile_desire_path(relationship_profile, desire), method: :patch, class: "inline-flex min-h-10 items-center justify-center rounded-lg bg-emerald-800 px-4 py-2 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        <% end %>
        <%= button_to t("desires.item.delete"), relationship_profile_desire_path(relationship_profile, desire), method: :delete, form: { data: { turbo_confirm: t("desires.item.delete_confirm") } }, class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-red-300 bg-white px-4 py-2 text-sm font-semibold text-red-800 transition hover:bg-red-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-700" %>
      </div>
    </div>
  </article>
<% end %>
