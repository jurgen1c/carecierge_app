<% form_url = desire.persisted? ? relationship_profile_desire_path(relationship_profile, desire) : relationship_profile_desires_path(relationship_profile) %>

<%= form_with model: desire, url: form_url, method: desire.persisted? ? :patch : :post, class: "rounded-xl border border-stone-200 bg-white p-4" do |form| %>
  <div>
    <h3 class="text-base font-semibold text-stone-950"><%= desire.persisted? ? t("desires.form.edit_title") : t("desires.form.new_title") %></h3>
    <p class="mt-1 text-sm leading-6 text-stone-700"><%= t("desires.form.body") %></p>
  </div>

  <% if desire.errors.any? %>
    <div class="mt-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-950">
      <p class="font-semibold"><%= t("desires.form.errors_heading", count: desire.errors.count) %></p>
      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% desire.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mt-4 grid gap-4 sm:grid-cols-2">
    <div class="sm:col-span-2">
      <%= form.label :title, t("desires.form.title"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.text_field :title, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20", placeholder: t("desires.form.title_placeholder") %>
    </div>

    <div>
      <%= form.label :category, t("desires.form.category"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.select :category, Desire.category_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>

    <% if desire.status.in?(Desire::EDITABLE_STATUSES) %>
      <div>
        <%= form.label :status, t("desires.form.status"), class: "block text-sm font-medium text-stone-800" %>
        <%= form.select :status, Desire.editable_status_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>
    <% else %>
      <div>
        <p class="block text-sm font-medium text-stone-800"><%= t("desires.form.status") %></p>
        <p class="mt-2 min-h-11 rounded-lg border border-stone-200 bg-stone-50 px-3 py-2 text-base text-stone-700"><%= desire.status_label %></p>
      </div>
    <% end %>

    <div>
      <%= form.label :captured_on, t("desires.form.captured_on"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.date_field :captured_on, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>
  </div>

  <div class="mt-4">
    <%= form.label :notes, t("desires.form.notes"), class: "block text-sm font-medium text-stone-800" %>
    <%= form.text_area :notes, rows: 3, class: "mt-2 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20", placeholder: t("desires.form.notes_placeholder") %>
  </div>

  <div class="mt-4 flex flex-wrap items-center gap-3">
    <%= form.submit desire.persisted? ? t("desires.form.update") : t("desires.form.create"), class: "inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <% if desire.persisted? %>
      <%= link_to t("desires.form.cancel"), relationship_profile_path(relationship_profile, anchor: dom_id(desire, :row)), data: { turbo_frame: "_top" }, class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <% end %>
  </div>
<% end %>
