<% content_for :title, t(".title") %>

<main class="flex flex-1 items-center justify-center py-10">
  <section class="w-full max-w-md rounded-xl border border-stone-200 bg-white p-6">
    <p class="text-sm font-semibold text-emerald-800"><%= t(".kicker") %></p>
    <h1 class="mt-3 text-2xl font-semibold text-stone-950"><%= t(".heading") %></h1>
    <p class="mt-3 text-sm leading-6 text-stone-700"><%= t(".body") %></p>

    <div class="mt-6">
      <%= render "devise/shared/error_messages", resource: resource %>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-6 space-y-5" }) do |f| %>
      <div>
        <%= f.label :email, t(".email"), class: "block text-sm font-medium text-stone-900" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-2 block min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 shadow-sm outline-none transition placeholder:text-stone-600 focus:border-emerald-700 focus:ring-2 focus:ring-emerald-700/20" %>
      </div>

      <div>
        <%= f.label :password, t(".password"), class: "block text-sm font-medium text-stone-900" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "mt-2 block min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 shadow-sm outline-none transition placeholder:text-stone-600 focus:border-emerald-700 focus:ring-2 focus:ring-emerald-700/20" %>
        <p class="mt-2 text-sm text-stone-700"><%= t(".password_hint", count: @minimum_password_length || 6) %></p>
      </div>

      <div>
        <%= f.label :password_confirmation, t(".password_confirmation"), class: "block text-sm font-medium text-stone-900" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-2 block min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 shadow-sm outline-none transition placeholder:text-stone-600 focus:border-emerald-700 focus:ring-2 focus:ring-emerald-700/20" %>
      </div>

      <%= f.submit t(".submit"), class: "inline-flex min-h-11 w-full cursor-pointer items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <% end %>

    <p class="mt-6 text-center text-sm text-stone-700">
      <%= t(".existing_account") %>
      <%= link_to t(".sign_in"), new_user_session_path, class: "font-semibold text-emerald-800 underline-offset-4 hover:underline" %>
    </p>
  </section>
</main>
