<% content_for :title, t(".title") %>

<main class="flex flex-1 items-center justify-center py-10">
  <section class="w-full max-w-md rounded-xl border border-stone-200 bg-white p-6">
    <p class="text-sm font-semibold text-emerald-800"><%= t(".kicker") %></p>
    <h1 class="mt-3 text-2xl font-semibold text-stone-950"><%= t(".heading") %></h1>
    <p class="mt-3 text-sm leading-6 text-stone-700"><%= t(".body") %></p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-6 space-y-5" }) do |f| %>
      <div>
        <%= f.label :email, t(".email"), class: "block text-sm font-medium text-stone-900" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-2 block min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 shadow-sm outline-none transition placeholder:text-stone-600 focus:border-emerald-700 focus:ring-2 focus:ring-emerald-700/20" %>
      </div>

      <div>
        <%= f.label :password, t(".password"), class: "block text-sm font-medium text-stone-900" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "mt-2 block min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 shadow-sm outline-none transition placeholder:text-stone-600 focus:border-emerald-700 focus:ring-2 focus:ring-emerald-700/20" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-3">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-stone-300 text-emerald-800 focus:ring-emerald-700" %>
          <%= f.label :remember_me, t(".remember_me"), class: "text-sm text-stone-700" %>
        </div>
      <% end %>

      <%= f.submit t(".submit"), class: "inline-flex min-h-11 w-full cursor-pointer items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <% end %>

    <div class="mt-6 flex flex-col gap-2 text-center text-sm text-stone-700">
      <%= link_to t(".forgot_password"), new_user_password_path, class: "font-semibold text-emerald-800 underline-offset-4 hover:underline" %>
      <% if devise_mapping.confirmable? %>
        <%= link_to t(".resend_confirmation"), new_user_confirmation_path, class: "font-semibold text-emerald-800 underline-offset-4 hover:underline" %>
      <% end %>
      <% if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) %>
        <%= link_to t(".resend_unlock"), new_user_unlock_path, class: "font-semibold text-emerald-800 underline-offset-4 hover:underline" %>
      <% end %>
      <span>
        <%= t(".new_account") %>
        <%= link_to t(".create_account"), new_user_registration_path, class: "font-semibold text-emerald-800 underline-offset-4 hover:underline" %>
      </span>
    </div>

    <% if devise_mapping.omniauthable? %>
      <div class="mt-6 border-t border-stone-200 pt-6">
        <% resource_class.omniauth_providers.each do |provider| %>
          <% next unless provider == :google_oauth2 %>

          <%= button_to t(".sign_in_with_google"), user_google_oauth2_omniauth_authorize_path, method: :post, class: "inline-flex min-h-11 w-full cursor-pointer items-center justify-center rounded-lg border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition hover:bg-stone-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        <% end %>
      </div>
    <% end %>
  </section>
</main>
