<% form_url = important_date.persisted? ? relationship_profile_important_date_path(relationship_profile, important_date) : relationship_profile_important_dates_path(relationship_profile) %>

<%= form_with model: important_date, url: form_url, method: important_date.persisted? ? :patch : :post, class: "rounded-xl border border-stone-200 bg-white p-4" do |form| %>
  <div class="flex items-start justify-between gap-3">
    <div>
      <h3 class="text-base font-semibold text-stone-950"><%= important_date.persisted? ? t("important_dates.form.edit_title") : t("important_dates.form.new_title") %></h3>
      <p class="mt-1 text-sm leading-6 text-stone-700"><%= t("important_dates.form.body") %></p>
    </div>
  </div>

  <% if important_date.errors.any? %>
    <div class="mt-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-950">
      <p class="font-semibold"><%= t("important_dates.form.errors_heading", count: important_date.errors.count) %></p>
      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% important_date.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mt-4 grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :date_type, t("important_dates.form.date_type"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.select :date_type, ImportantDate.date_type_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>

    <div>
      <%= form.label :starts_on, t("important_dates.form.starts_on"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.date_field :starts_on, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>

    <div>
      <%= form.label :title, t("important_dates.form.title"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.text_field :title, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20", placeholder: t("important_dates.form.title_placeholder") %>
    </div>

    <div>
      <%= form.label :recurrence, t("important_dates.form.recurrence"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.select :recurrence, ImportantDate.recurrence_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>

    <div>
      <%= form.label :importance_level, t("important_dates.form.importance_level"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.select :importance_level, ImportantDate.importance_level_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>

    <div>
      <%= form.label :reminder_schedule, t("important_dates.form.reminder_schedule"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.select :reminder_schedule, ImportantDate.reminder_schedule_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>
  </div>

  <div class="mt-4">
    <%= form.label :notes, t("important_dates.form.notes"), class: "block text-sm font-medium text-stone-800" %>
    <%= form.text_area :notes, rows: 3, class: "mt-2 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20", placeholder: t("important_dates.form.notes_placeholder") %>
  </div>

  <div class="mt-4 flex flex-wrap items-center gap-3">
    <%= form.submit important_date.persisted? ? t("important_dates.form.update") : t("important_dates.form.create"), class: "inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <% if important_date.persisted? %>
      <%= link_to t("important_dates.form.cancel"), relationship_profile_path(relationship_profile, anchor: dom_id(important_date, :row)), data: { turbo_frame: "_top" }, class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <% end %>
  </div>
<% end %>
