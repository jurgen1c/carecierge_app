<%= turbo_frame_tag dom_id(important_date) do %>
  <% occurrence = important_date.next_occurrence_on %>
  <article id="<%= dom_id(important_date, :row) %>" class="rounded-lg border border-stone-200 bg-white p-4">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-900"><%= important_date.date_type_label %></span>
          <span class="rounded-full border border-orange-200 bg-orange-50 px-3 py-1 text-xs font-medium text-orange-950"><%= important_date.importance_level_label %></span>
          <span class="rounded-full bg-stone-100 px-3 py-1 text-xs font-medium text-stone-700"><%= important_date.recurrence_label %></span>
        </div>

        <h4 class="mt-3 text-base font-semibold text-stone-950"><%= important_date.display_title %></h4>
        <dl class="mt-2 grid gap-2 text-sm text-stone-700 sm:grid-cols-2">
          <div>
            <dt class="font-medium text-stone-800"><%= t("important_dates.item.date") %></dt>
            <dd class="mt-1"><%= l(occurrence || important_date.starts_on, format: :important_date) %></dd>
          </div>
          <div>
            <dt class="font-medium text-stone-800"><%= t("important_dates.item.reminder") %></dt>
            <dd class="mt-1"><%= important_date.reminder_schedule_label %></dd>
          </div>
        </dl>
        <% if important_date.notes.present? %>
          <p class="mt-3 text-sm leading-6 text-stone-700"><%= important_date.notes %></p>
        <% end %>
      </div>

      <div class="flex shrink-0 flex-wrap gap-2">
        <%= link_to t("important_dates.item.add_reminder"), new_reminder_path(relationship_profile_id: relationship_profile.id, important_date_id: important_date.id), data: { turbo_frame: "_top" }, class: "inline-flex min-h-10 items-center justify-center rounded-lg bg-emerald-800 px-4 py-2 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        <% if planning_link_available %>
          <%= link_to t("important_dates.item.plan_ahead"), "##{dom_id(important_date, :planning)}", data: { turbo_frame: "_top" }, class: "inline-flex min-h-10 items-center justify-center rounded-lg bg-orange-100 px-4 py-2 text-sm font-semibold text-orange-950 transition hover:bg-orange-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-700" %>
        <% end %>
        <%= link_to t("important_dates.item.edit"), edit_relationship_profile_important_date_path(relationship_profile, important_date), class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-stone-300 bg-white px-4 py-2 text-sm font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        <%= button_to t("important_dates.item.delete"), relationship_profile_important_date_path(relationship_profile, important_date), method: :delete, form: { data: { turbo_confirm: t("important_dates.item.delete_confirm") } }, class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-red-300 bg-white px-4 py-2 text-sm font-semibold text-red-800 transition hover:bg-red-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-700" %>
      </div>
    </div>
  </article>
<% end %>
