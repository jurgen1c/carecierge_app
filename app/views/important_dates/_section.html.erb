<%= turbo_frame_tag "important_dates_section" do %>
  <% important_dates = relationship_profile.important_dates.reject(&:new_record?).sort_by { |date| [date.next_occurrence_on || date.starts_on, date.display_title.downcase] } %>
  <% planning_dates = relationship_profile.planning_important_dates(limit: 4) %>
  <% planning_date_ids = planning_dates.map(&:id) %>

  <section class="rounded-2xl border border-stone-200 bg-white p-5 shadow-sm shadow-stone-200/40">
    <div class="flex flex-col gap-4 border-b border-stone-200 pb-5 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <p class="text-sm font-semibold text-emerald-800"><%= t("important_dates.section.kicker") %></p>
        <h2 class="mt-2 text-xl font-semibold text-stone-950"><%= t("important_dates.section.title") %></h2>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-stone-700"><%= t("important_dates.section.body") %></p>
      </div>
      <span class="inline-flex w-fit items-center rounded-full border border-orange-200 bg-orange-50 px-3 py-1 text-xs font-semibold text-orange-900"><%= t("important_dates.section.turbo_hint") %></span>
    </div>

    <div class="mt-5 grid gap-5 xl:grid-cols-[1.1fr_0.9fr]">
      <div class="rounded-xl border border-stone-200 bg-stone-50/70 p-4">
        <div class="flex items-center justify-between gap-3">
          <h3 class="text-base font-semibold text-stone-950"><%= t("important_dates.section.timeline_title") %></h3>
          <span class="text-xs font-medium text-stone-600"><%= t("important_dates.section.date_count", count: important_dates.size) %></span>
        </div>

        <% if important_dates.any? %>
          <div class="mt-4 grid gap-3">
            <% important_dates.each do |date| %>
              <%= render "important_dates/important_date", relationship_profile:, important_date: date, planning_link_available: planning_date_ids.include?(date.id) %>
            <% end %>
          </div>
        <% else %>
          <div class="mt-4 rounded-lg border border-dashed border-stone-300 bg-white px-4 py-5">
            <p class="text-sm font-semibold text-stone-950"><%= t("important_dates.section.empty_title") %></p>
            <p class="mt-2 text-sm leading-6 text-stone-700"><%= t("important_dates.section.empty_body") %></p>
          </div>
        <% end %>
      </div>

      <div class="grid gap-4">
        <section class="rounded-xl border border-orange-200 bg-orange-50/70 p-4">
          <h3 class="text-base font-semibold text-stone-950"><%= t("important_dates.section.suggestions_title") %></h3>
          <% if planning_dates.any? %>
            <div class="mt-4 grid gap-3">
              <% planning_dates.each do |date| %>
                <% occurrence = date.next_occurrence_on %>
                <article id="<%= dom_id(date, :planning) %>" class="rounded-lg border border-orange-200 bg-white p-4">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="rounded-full bg-orange-100 px-3 py-1 text-xs font-semibold text-orange-950"><%= t("important_dates.section.plan_ahead") %></span>
                    <% if occurrence.present? %>
                      <span class="text-xs font-medium text-stone-600"><%= t("important_dates.section.days_until", count: date.days_until) %></span>
                    <% end %>
                  </div>
                  <p class="mt-3 text-sm font-semibold text-stone-950"><%= date.display_title %></p>
                  <p class="mt-1 text-sm leading-6 text-stone-700"><%= date.planning_prompt %></p>
                </article>
              <% end %>
            </div>
          <% else %>
            <p class="mt-3 text-sm leading-6 text-stone-700"><%= t("important_dates.section.no_suggestions") %></p>
          <% end %>
        </section>

        <%= turbo_frame_tag "new_important_date", src: new_relationship_profile_important_date_path(relationship_profile), loading: :lazy do %>
          <div class="rounded-xl border border-stone-200 bg-white p-4">
            <h3 class="text-base font-semibold text-stone-950"><%= t("important_dates.form.new_title") %></h3>
            <p class="mt-1 text-sm leading-6 text-stone-700"><%= t("important_dates.form.body") %></p>
            <%= link_to t("important_dates.form.create"), new_relationship_profile_important_date_path(relationship_profile), class: "mt-4 inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
          </div>
        <% end %>
      </div>
    </div>
  </section>
<% end %>
