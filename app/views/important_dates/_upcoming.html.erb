<%= turbo_frame_tag "upcoming_important_dates" do %>
  <% upcoming_dates = relationship_profile.upcoming_important_dates(limit: 3) %>
  <section class="rounded-xl border border-stone-200 bg-white p-5">
    <div class="flex items-center justify-between gap-3">
      <h2 class="text-base font-semibold text-stone-950"><%= t("important_dates.upcoming.title") %></h2>
      <%= link_to t("important_dates.upcoming.add"), "#new_important_date", data: { turbo_frame: "_top" }, class: "text-sm font-semibold text-emerald-800 hover:text-emerald-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    </div>

    <% if upcoming_dates.any? %>
      <div class="mt-4 space-y-3">
        <% upcoming_dates.each do |date| %>
          <% occurrence = date.next_occurrence_on %>
          <article class="rounded-lg border border-stone-200 bg-stone-50 px-4 py-3">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-sm font-semibold text-stone-950"><%= date.display_title %></p>
                <p class="mt-1 text-xs font-medium text-stone-600"><%= l(occurrence || date.starts_on, format: :important_date) %></p>
              </div>
              <% if date.planning_opportunity? %>
                <%= link_to t("important_dates.upcoming.plan_ahead"), "##{dom_id(date, :planning)}", data: { turbo_frame: "_top" }, class: "rounded-full bg-orange-100 px-3 py-1 text-xs font-semibold text-orange-950 hover:bg-orange-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-700" %>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <p class="mt-3 text-sm leading-6 text-stone-700"><%= t("important_dates.upcoming.empty") %></p>
    <% end %>
  </section>
<% end %>
