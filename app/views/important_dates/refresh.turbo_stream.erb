<%= turbo_stream.replace "important_dates_section" do %>
  <%= render "important_dates/section", relationship_profile: @relationship_profile, important_date: @important_date %>
<% end %>

<%= turbo_stream.replace "upcoming_important_dates" do %>
  <%= render "important_dates/upcoming", relationship_profile: @relationship_profile %>
<% end %>

<%= turbo_stream.replace "flash" do %>
  <div id="flash" class="mb-5 space-y-3" aria-live="polite">
    <% if notice.present? %>
      <p class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-950"><%= notice %></p>
    <% end %>
    <% if alert.present? %>
      <p class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-950"><%= alert %></p>
    <% end %>
  </div>
<% end %>
