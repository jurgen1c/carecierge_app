<% form_url = interaction.persisted? ? relationship_profile_interaction_path(relationship_profile, interaction) : relationship_profile_interactions_path(relationship_profile) %>

<%= form_with model: interaction, url: form_url, method: interaction.persisted? ? :patch : :post, class: "mt-4 rounded-xl border border-stone-200 bg-stone-50 p-4" do |form| %>
  <h3 class="text-base font-semibold text-stone-950"><%= interaction.persisted? ? t("contact_rhythm.form.edit_title") : t("contact_rhythm.form.new_title") %></h3>
  <p class="mt-1 text-sm leading-6 text-stone-700"><%= t("contact_rhythm.form.body") %></p>

  <% if interaction.errors.any? %>
    <div class="mt-4 rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-950">
      <p class="font-semibold"><%= t("contact_rhythm.form.errors") %></p>
      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% interaction.errors.full_messages.each do |message| %><li><%= message %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="mt-4 grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :interaction_type, t("contact_rhythm.form.type"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.select :interaction_type,
        Interaction::MANUAL_TYPES.map { |value| [ t("contact_rhythm.interaction_types.#{value}"), value ] },
        { include_blank: t("contact_rhythm.form.choose_type") },
        class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>
    <div>
      <%= form.label :occurred_at, t("contact_rhythm.form.occurred_at"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.datetime_local_field :occurred_at, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>
    <div class="sm:col-span-2">
      <%= form.label :notes, t("contact_rhythm.form.notes"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.text_area :notes, rows: 3, class: "mt-2 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20", placeholder: t("contact_rhythm.form.notes_placeholder") %>
    </div>
  </div>

  <div class="mt-4 flex flex-wrap gap-3">
    <%= form.submit interaction.persisted? ? t("contact_rhythm.form.update") : t("contact_rhythm.form.create"), class: "inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <% if interaction.persisted? %>
      <%= link_to t("contact_rhythm.form.cancel"), relationship_profile_path(relationship_profile, anchor: dom_id(interaction)), data: { turbo_frame: "_top" }, class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <% end %>
  </div>
<% end %>
