<%= turbo_frame_tag interaction do %>
  <article class="py-4 first:pt-3 last:pb-3">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-2">
          <h4 class="text-sm font-semibold text-stone-950"><%= t("contact_rhythm.interaction_types.#{interaction.interaction_type}") %></h4>
          <span class="rounded-full border border-stone-200 bg-stone-50 px-2.5 py-1 text-xs font-medium text-stone-700">
            <%= interaction.manual? ? t("contact_rhythm.interactions.manual") : t("contact_rhythm.interactions.derived_from", source: t("contact_rhythm.sources.#{interaction.source_type.underscore}")) %>
          </span>
        </div>
        <% if interaction.display_notes.present? %>
          <p class="mt-2 whitespace-pre-line text-sm leading-6 text-stone-700"><%= interaction.display_notes %></p>
        <% end %>
      </div>

      <div class="flex shrink-0 flex-wrap items-center gap-3 sm:justify-end">
        <time datetime="<%= interaction.occurred_at.iso8601 %>" class="text-xs font-medium text-stone-600">
          <%= l(interaction.occurred_at, format: :interaction_day) %> · <%= l(interaction.occurred_at, format: :interaction_time) %>
        </time>
        <% if interaction.manual? %>
          <%= link_to t("contact_rhythm.interactions.edit"),
            edit_relationship_profile_interaction_path(relationship_profile, interaction),
            class: "inline-flex min-h-11 items-center text-sm font-semibold text-emerald-800 hover:text-emerald-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
          <%= button_to t("contact_rhythm.interactions.delete"),
            relationship_profile_interaction_path(relationship_profile, interaction),
            method: :delete,
            form: { data: { turbo_confirm: t("contact_rhythm.interactions.delete_confirm") } },
            class: "inline-flex min-h-11 items-center text-sm font-semibold text-red-800 hover:text-red-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-700" %>
        <% end %>
      </div>
    </div>
  </article>
<% end %>
