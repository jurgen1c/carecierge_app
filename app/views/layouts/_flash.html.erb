<div id="flash" aria-live="polite">
  <% if notice.present? || alert.present? %>
    <div class="mb-5 space-y-3">
      <% if notice.present? %>
        <p class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-950"><%= notice %></p>
      <% end %>
      <% if alert.present? %>
        <p class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-950"><%= alert %></p>
      <% end %>
    </div>
  <% end %>
</div>
