<% form_url = memory_record.persisted? ? relationship_profile_memory_record_path(relationship_profile, memory_record) : relationship_profile_memory_records_path(relationship_profile) %>

<%= form_with model: memory_record, url: form_url, method: memory_record.persisted? ? :patch : :post, class: "rounded-xl border border-stone-200 bg-white p-4" do |form| %>
  <div>
    <h3 class="text-base font-semibold text-stone-950"><%= memory_record.persisted? ? t("memory_records.form.edit_title") : t("memory_records.form.new_title") %></h3>
    <p class="mt-1 text-sm leading-6 text-stone-700"><%= t("memory_records.form.body") %></p>
  </div>

  <% if memory_record.errors.any? %>
    <div class="mt-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-950">
      <p class="font-semibold"><%= t("memory_records.form.errors_heading", count: memory_record.errors.count) %></p>
      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% memory_record.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mt-4 grid gap-4 sm:grid-cols-2">
    <div class="sm:col-span-2">
      <%= form.label :title, t("memory_records.form.title"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.text_field :title, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20", placeholder: t("memory_records.form.title_placeholder") %>
    </div>

    <div class="sm:col-span-2">
      <%= form.label :body, t("memory_records.form.memory"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.text_area :body, rows: 4, class: "mt-2 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20", placeholder: t("memory_records.form.memory_placeholder") %>
    </div>

    <div>
      <%= form.label :source, t("memory_records.form.source"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.select :source, MemoryRecord.source_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>

    <div>
      <%= form.label :confidence, t("memory_records.form.confidence"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.select :confidence, MemoryRecord.confidence_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>

    <div>
      <%= form.label :status, t("memory_records.form.status"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.select :status, MemoryRecord.status_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>

    <div>
      <%= form.label :stale_after, t("memory_records.form.stale_after"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.date_field :stale_after, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>

    <% if memory_record.persisted? %>
      <div class="sm:col-span-2">
        <%= label_tag "memory_record_correction_note", t("memory_records.form.correction_note"), class: "block text-sm font-medium text-stone-800" %>
        <%= text_area_tag "memory_record[correction_note]", nil, id: "memory_record_correction_note", rows: 3, class: "mt-2 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20", placeholder: t("memory_records.form.correction_note_placeholder") %>
      </div>
    <% end %>
  </div>

  <div class="mt-4 flex flex-wrap items-center gap-3">
    <%= form.submit memory_record.persisted? ? t("memory_records.form.update") : t("memory_records.form.create"), class: "inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <% if memory_record.persisted? %>
      <%= link_to t("memory_records.form.cancel"), relationship_profile_path(relationship_profile, anchor: dom_id(memory_record, :row)), data: { turbo_frame: "_top" }, class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <% end %>
  </div>
<% end %>
