<%= turbo_frame_tag dom_id(memory_record) do %>
  <article id="<%= dom_id(memory_record, :row) %>" class="rounded-lg border border-stone-200 bg-white p-4">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-900"><%= memory_record.source_label %></span>
          <span class="rounded-full bg-stone-100 px-3 py-1 text-xs font-semibold text-stone-800"><%= memory_record.confidence_label %></span>
          <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-stone-700 ring-1 ring-inset ring-stone-200"><%= memory_record.status_label %></span>
        </div>
        <h4 class="mt-3 text-sm font-semibold text-stone-950"><%= memory_record.title %></h4>
        <p class="mt-1 whitespace-pre-line text-sm leading-6 text-stone-700"><%= memory_record.body %></p>
      </div>

      <div class="flex shrink-0 flex-wrap gap-2">
        <%= link_to t("memory_records.record.edit"), edit_relationship_profile_memory_record_path(relationship_profile, memory_record), class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-stone-300 bg-white px-3 py-2 text-xs font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        <% if memory_record.review_required? %>
          <%= button_to t("memory_records.record.mark_reviewed"), review_relationship_profile_memory_record_path(relationship_profile, memory_record), method: :patch, class: "inline-flex min-h-10 items-center justify-center rounded-lg bg-emerald-800 px-3 py-2 text-xs font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        <% end %>
        <%= button_to t("memory_records.record.delete"), relationship_profile_memory_record_path(relationship_profile, memory_record), method: :delete, form: { data: { turbo_confirm: t("memory_records.record.delete_confirm") } }, class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-red-200 bg-white px-3 py-2 text-xs font-semibold text-red-800 transition hover:bg-red-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-700" %>
      </div>
    </div>

    <dl class="mt-4 grid gap-3 border-t border-stone-200 pt-4 text-xs text-stone-700 sm:grid-cols-3">
      <div>
        <dt class="font-semibold text-stone-800"><%= t("memory_records.record.stale_after") %></dt>
        <dd class="mt-1"><%= memory_record.stale_after.present? ? l(memory_record.stale_after, format: :memory_stale_after) : t("memory_records.record.no_stale_after") %></dd>
      </div>
      <div>
        <dt class="font-semibold text-stone-800"><%= t("memory_records.record.review_status") %></dt>
        <dd class="mt-1"><%= memory_record.review_required? ? t("memory_records.record.needs_review") : t("memory_records.record.review_current") %></dd>
      </div>
      <div>
        <dt class="font-semibold text-stone-800"><%= t("memory_records.record.automation_status") %></dt>
        <dd class="mt-1"><%= memory_record.high_impact_automation_allowed? ? t("memory_records.record.automation_allowed") : t("memory_records.record.automation_blocked") %></dd>
      </div>
    </dl>

    <% if memory_record.high_impact_automation_blocked? %>
      <div class="mt-4 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2">
        <p class="text-sm font-semibold text-amber-950"><%= t("memory_records.record.approval_title") %></p>
        <p class="mt-1 text-sm leading-6 text-amber-900"><%= t("memory_records.record.approval_body") %></p>
        <%= button_to t("memory_records.record.approve_automation"), approve_high_impact_automation_relationship_profile_memory_record_path(relationship_profile, memory_record), method: :patch, class: "mt-3 inline-flex min-h-10 items-center justify-center rounded-lg border border-amber-300 bg-white px-3 py-2 text-xs font-semibold text-amber-950 transition hover:bg-amber-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-700" %>
      </div>
    <% end %>
  </article>
<% end %>
