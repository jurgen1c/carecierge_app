<%= turbo_frame_tag "memory_records_section" do %>
  <% memory_records = relationship_profile.memory_records.ordered.to_a %>
  <% memory_record_counts = memory_records.each_with_object({ review: 0, blocked: 0 }) do |memory_record, counts| %>
    <% counts[:review] += 1 if memory_record.review_required? %>
    <% counts[:blocked] += 1 if memory_record.high_impact_automation_blocked? %>
  <% end %>
  <% review_count = memory_record_counts[:review] %>
  <% blocked_count = memory_record_counts[:blocked] %>

  <section class="rounded-2xl border border-stone-200 bg-white p-5 shadow-sm shadow-stone-200/40">
    <div class="flex flex-col gap-4 border-b border-stone-200 pb-5 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <p class="text-sm font-semibold text-emerald-800"><%= t("memory_records.section.kicker") %></p>
        <h2 class="mt-2 text-xl font-semibold text-stone-950"><%= t("memory_records.section.title") %></h2>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-stone-700"><%= t("memory_records.section.body") %></p>
      </div>
      <div class="flex flex-wrap gap-2">
        <span class="inline-flex w-fit items-center rounded-full border border-stone-200 bg-stone-50 px-3 py-1 text-xs font-semibold text-stone-800"><%= t("memory_records.section.review_count", count: review_count) %></span>
        <span class="inline-flex w-fit items-center rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-900"><%= t("memory_records.section.blocked_count", count: blocked_count) %></span>
      </div>
    </div>

    <div class="mt-5 grid gap-5 xl:grid-cols-[1.1fr_0.9fr]">
      <div class="rounded-xl border border-stone-200 bg-stone-50/70 p-4">
        <div class="flex items-center justify-between gap-3">
          <h3 class="text-base font-semibold text-stone-950"><%= t("memory_records.section.list_title") %></h3>
          <span class="text-xs font-medium text-stone-600"><%= t("memory_records.section.record_count", count: memory_records.size) %></span>
        </div>

        <% if memory_records.any? %>
          <div class="mt-4 grid gap-3">
            <% memory_records.each do |memory_record| %>
              <%= render "memory_records/memory_record", relationship_profile:, memory_record: %>
            <% end %>
          </div>
        <% else %>
          <div class="mt-4 rounded-lg border border-dashed border-stone-300 bg-white px-4 py-5">
            <p class="text-sm font-semibold text-stone-950"><%= t("memory_records.section.empty_title") %></p>
            <p class="mt-2 text-sm leading-6 text-stone-700"><%= t("memory_records.section.empty_body") %></p>
          </div>
        <% end %>
      </div>

      <div class="grid gap-4">
        <section class="rounded-xl border border-emerald-200 bg-emerald-50/70 p-4">
          <h3 class="text-base font-semibold text-stone-950"><%= t("memory_records.section.trust_title") %></h3>
          <p class="mt-2 text-sm leading-6 text-stone-700"><%= t("memory_records.section.trust_body") %></p>
          <dl class="mt-4 grid gap-3 text-sm">
            <div>
              <dt class="font-semibold text-stone-800"><%= t("memory_records.section.review_label") %></dt>
              <dd class="mt-1 text-stone-700"><%= t("memory_records.section.review_value", count: review_count) %></dd>
            </div>
            <div>
              <dt class="font-semibold text-stone-800"><%= t("memory_records.section.automation_label") %></dt>
              <dd class="mt-1 text-stone-700"><%= t("memory_records.section.automation_value", count: blocked_count) %></dd>
            </div>
          </dl>
        </section>

        <%= turbo_frame_tag "new_memory_record", src: new_relationship_profile_memory_record_path(relationship_profile), loading: :lazy do %>
          <div class="rounded-xl border border-stone-200 bg-white p-4">
            <h3 class="text-base font-semibold text-stone-950"><%= t("memory_records.form.new_title") %></h3>
            <p class="mt-1 text-sm leading-6 text-stone-700"><%= t("memory_records.form.body") %></p>
            <%= link_to t("memory_records.form.create"), new_relationship_profile_memory_record_path(relationship_profile), class: "mt-4 inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
          </div>
        <% end %>
      </div>
    </div>
  </section>
<% end %>
