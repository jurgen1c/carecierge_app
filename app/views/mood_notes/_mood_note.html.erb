<% selected_type = local_assigns[:selected_type] %>

<%= turbo_frame_tag dom_id(mood_note) do %>
  <article id="<%= dom_id(mood_note, :row) %>" class="rounded-lg border border-stone-200 bg-white p-4">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-900"><%= mood_note.category_label %></span>
          <time datetime="<%= mood_note.observed_at.iso8601 %>" class="rounded-full bg-white px-3 py-1 text-xs font-medium text-stone-700 ring-1 ring-inset ring-stone-200"><%= l(mood_note.observed_at, format: :timeline_entry_day) %></time>
          <% if mood_note.timeline_visible? %>
            <span class="rounded-full bg-stone-100 px-3 py-1 text-xs font-medium text-stone-700"><%= t("mood_notes.note.on_timeline") %></span>
          <% end %>
        </div>
        <p class="mt-3 whitespace-pre-line text-sm leading-6 text-stone-800"><%= mood_note.observation %></p>

        <% if mood_note.supportive_action.present? || mood_note.follow_up_at.present? %>
          <dl class="mt-4 grid gap-3 border-t border-stone-200 pt-4 text-sm sm:grid-cols-2">
            <% if mood_note.supportive_action.present? %>
              <div>
                <dt class="font-semibold text-stone-900"><%= t("mood_notes.note.supportive_action") %></dt>
                <dd class="mt-1 leading-6 text-stone-700"><%= mood_note.supportive_action %></dd>
              </div>
            <% end %>
            <% if mood_note.follow_up_at.present? %>
              <div>
                <dt class="font-semibold text-stone-900"><%= t("mood_notes.note.follow_up") %></dt>
                <dd class="mt-1 text-stone-700">
                  <time datetime="<%= mood_note.follow_up_at.iso8601 %>"><%= l(mood_note.follow_up_at, format: :timeline_entry_day) %> · <%= l(mood_note.follow_up_at, format: :timeline_entry_time) %></time>
                </dd>
              </div>
            <% end %>
          </dl>
        <% end %>
      </div>

      <div class="flex shrink-0 flex-wrap gap-2">
        <%= link_to t("mood_notes.note.edit"), edit_relationship_profile_mood_note_path(relationship_profile, mood_note, timeline_type: selected_type), class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-stone-300 bg-white px-3 py-2 text-xs font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        <%= button_to t("mood_notes.note.delete"), relationship_profile_mood_note_path(relationship_profile, mood_note, timeline_type: selected_type), method: :delete, form: { data: { turbo_confirm: t("mood_notes.note.delete_confirm") } }, class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-red-200 bg-white px-3 py-2 text-xs font-semibold text-red-800 transition hover:bg-red-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-700" %>
      </div>
    </div>
  </article>
<% end %>
