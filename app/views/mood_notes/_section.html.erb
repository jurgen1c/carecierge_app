<%= turbo_frame_tag "mood_notes_section" do %>
  <% selected_type = local_assigns[:selected_type] %>
  <% mood_notes = relationship_profile.mood_notes.ordered.to_a %>
  <% follow_up_count = mood_notes.count { |mood_note| mood_note.follow_up_at.present? } %>

  <section class="rounded-2xl border border-stone-200 bg-white p-5 shadow-sm shadow-stone-200/40">
    <div class="flex flex-col gap-4 border-b border-stone-200 pb-5 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <p class="text-sm font-semibold text-emerald-800"><%= t("mood_notes.section.kicker") %></p>
        <h2 class="mt-2 text-xl font-semibold text-stone-950"><%= t("mood_notes.section.title") %></h2>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-stone-700"><%= t("mood_notes.section.body") %></p>
      </div>
      <div class="flex flex-wrap gap-2">
        <span class="inline-flex w-fit items-center rounded-full border border-stone-200 bg-stone-50 px-3 py-1 text-xs font-semibold text-stone-800"><%= t("mood_notes.section.note_count", count: mood_notes.size) %></span>
        <span class="inline-flex w-fit items-center rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-900"><%= t("mood_notes.section.follow_up_count", count: follow_up_count) %></span>
      </div>
    </div>

    <div class="mt-5 grid gap-5 xl:grid-cols-[1.1fr_0.9fr]">
      <div class="rounded-xl border border-stone-200 bg-stone-50/70 p-4">
        <div class="flex items-center justify-between gap-3">
          <h3 class="text-base font-semibold text-stone-950"><%= t("mood_notes.section.list_title") %></h3>
          <span class="text-xs font-medium text-stone-600"><%= t("mood_notes.section.shown_count", count: mood_notes.size) %></span>
        </div>

        <% if mood_notes.any? %>
          <div class="mt-4 grid gap-3">
            <% mood_notes.each do |mood_note| %>
              <%= render "mood_notes/mood_note", relationship_profile:, mood_note:, selected_type: %>
            <% end %>
          </div>
        <% else %>
          <div class="mt-4 rounded-lg border border-dashed border-stone-300 bg-white px-4 py-5">
            <p class="text-sm font-semibold text-stone-950"><%= t("mood_notes.section.empty_title") %></p>
            <p class="mt-2 text-sm leading-6 text-stone-700"><%= t("mood_notes.section.empty_body") %></p>
          </div>
        <% end %>
      </div>

      <div class="grid content-start gap-4">
        <aside class="rounded-xl border border-emerald-200 bg-emerald-50/70 p-4">
          <h3 class="text-base font-semibold text-stone-950"><%= t("mood_notes.section.guardrail_title") %></h3>
          <p class="mt-2 text-sm leading-6 text-stone-700"><%= t("mood_notes.section.guardrail_body") %></p>
          <ul class="mt-4 grid gap-2 text-sm leading-6 text-stone-700">
            <li><span class="font-semibold text-stone-900"><%= t("mood_notes.section.observe_label") %></span> <%= t("mood_notes.section.observe_body") %></li>
            <li><span class="font-semibold text-stone-900"><%= t("mood_notes.section.support_label") %></span> <%= t("mood_notes.section.support_body") %></li>
          </ul>
        </aside>

        <%= turbo_frame_tag "new_mood_note", src: new_relationship_profile_mood_note_path(relationship_profile, timeline_type: selected_type), loading: :lazy do %>
          <div class="rounded-xl border border-stone-200 bg-white p-4">
            <h3 class="text-base font-semibold text-stone-950"><%= t("mood_notes.form.new_title") %></h3>
            <p class="mt-1 text-sm leading-6 text-stone-700"><%= t("mood_notes.form.body") %></p>
            <%= link_to t("mood_notes.form.create"), new_relationship_profile_mood_note_path(relationship_profile, timeline_type: selected_type), class: "mt-4 inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
          </div>
        <% end %>
      </div>
    </div>
  </section>
<% end %>
