<% content_for :title, t("notification_preferences.edit.page_title") %>

<main class="flex flex-1 flex-col py-6">
  <%= link_to t("notification_preferences.edit.back"), reminders_path, class: "mb-5 inline-flex min-h-11 w-fit items-center text-sm font-semibold text-stone-700 hover:text-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>

  <%= form_with model: @notification_preference, url: notification_preference_path, method: :patch do |form| %>
    <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_18rem]">
      <div class="min-w-0 overflow-hidden rounded-xl border border-stone-200 bg-white">
        <header class="flex flex-col gap-4 border-b border-stone-200 px-4 py-5 sm:flex-row sm:items-start sm:justify-between sm:px-5">
          <div>
            <h1 class="text-2xl font-semibold text-stone-950"><%= t("notification_preferences.edit.heading") %></h1>
            <p class="mt-2 max-w-2xl text-sm leading-6 text-stone-700"><%= t("notification_preferences.edit.body") %></p>
          </div>
          <%= form.submit t("notification_preferences.edit.save"), class: "min-h-11 shrink-0 rounded-lg bg-emerald-800 px-5 py-2 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        </header>

        <% if @notification_preference.errors.any? %>
          <div class="m-4 rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-950 sm:m-5">
            <p class="font-semibold"><%= t("notification_preferences.edit.errors") %></p>
            <ul class="mt-2 list-disc space-y-1 pl-5">
              <% @notification_preference.errors.full_messages.each do |message| %><li><%= message %></li><% end %>
            </ul>
          </div>
        <% end %>

        <section aria-labelledby="delivery-channels-heading">
          <div class="border-b border-stone-200 bg-stone-50/70 px-4 py-3 sm:px-5">
            <h2 id="delivery-channels-heading" class="text-base font-semibold text-stone-950"><%= t("notification_preferences.edit.channels.title") %></h2>
            <p class="mt-1 text-sm leading-5 text-stone-600"><%= t("notification_preferences.edit.channels.body") %></p>
          </div>
          <div class="divide-y divide-stone-200">
            <%= component "notification_switch_row", form:, field: :in_app_enabled, title: t("notification_preferences.edit.channels.in_app"), description: t("notification_preferences.edit.channels.in_app_body") %>
            <%= component "notification_switch_row", form:, field: :email_enabled, title: t("notification_preferences.edit.channels.email"), description: t("notification_preferences.edit.channels.email_body") %>
            <%= component "notification_switch_row", form:, field: :push_enabled, title: t("notification_preferences.edit.channels.push"), description: t("notification_preferences.edit.channels.push_body"), availability: t("notification_preferences.edit.channels.saved_for_later") %>
            <%= component "notification_switch_row", form:, field: :sms_enabled, title: t("notification_preferences.edit.channels.sms"), description: t("notification_preferences.edit.channels.sms_body"), availability: t("notification_preferences.edit.channels.saved_for_later") %>
          </div>
        </section>

        <section aria-labelledby="quiet-hours-heading" class="border-t border-stone-200">
          <div class="border-b border-stone-200 bg-stone-50/70 px-4 py-3 sm:px-5">
            <h2 id="quiet-hours-heading" class="text-base font-semibold text-stone-950"><%= t("notification_preferences.edit.timing.title") %></h2>
            <p class="mt-1 text-sm leading-5 text-stone-600"><%= t("notification_preferences.edit.timing.body") %></p>
          </div>
          <%= component "notification_switch_row", form:, field: :quiet_hours_enabled, title: t("notification_preferences.edit.timing.quiet_hours"), description: t("notification_preferences.edit.timing.quiet_hours_body") %>
          <div class="grid gap-4 border-t border-stone-200 px-4 py-4 sm:grid-cols-3 sm:px-5">
            <div>
              <%= form.label :quiet_hours_start, t("notification_preferences.edit.timing.starts_at"), class: "block text-sm font-medium text-stone-800" %>
              <%= form.time_field :quiet_hours_start, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
            </div>
            <div>
              <%= form.label :quiet_hours_end, t("notification_preferences.edit.timing.ends_at"), class: "block text-sm font-medium text-stone-800" %>
              <%= form.time_field :quiet_hours_end, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
            </div>
            <div>
              <%= form.label :time_zone, t("notification_preferences.edit.timing.time_zone"), class: "block text-sm font-medium text-stone-800" %>
              <%= form.select :time_zone, reminder_time_zone_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
            </div>
          </div>
          <div class="border-t border-stone-200">
            <%= component "notification_switch_row", form:, field: :high_priority_alerts_enabled, title: t("notification_preferences.edit.timing.high_priority"), description: t("notification_preferences.edit.timing.high_priority_body"), attention: true %>
          </div>
        </section>

        <section aria-labelledby="reminder-defaults-heading" class="border-t border-stone-200">
          <div class="border-b border-stone-200 bg-stone-50/70 px-4 py-3 sm:px-5">
            <h2 id="reminder-defaults-heading" class="text-base font-semibold text-stone-950"><%= t("notification_preferences.edit.reminders.title") %></h2>
            <p class="mt-1 text-sm leading-5 text-stone-600"><%= t("notification_preferences.edit.reminders.body") %></p>
          </div>
          <div class="grid gap-4 px-4 py-4 sm:grid-cols-2 sm:px-5">
            <div>
              <%= form.label :reminder_frequency, t("notification_preferences.edit.reminders.frequency"), class: "block text-sm font-medium text-stone-800" %>
              <%= form.select :reminder_frequency, NotificationPreference.reminder_frequency_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
            </div>
            <div>
              <%= form.label :reminder_lead_minutes, t("notification_preferences.edit.reminders.lead"), class: "block text-sm font-medium text-stone-800" %>
              <%= form.select :reminder_lead_minutes, NotificationPreference.reminder_lead_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
              <p class="mt-2 text-xs leading-5 text-stone-600"><%= t("notification_preferences.edit.reminders.lead_help") %></p>
            </div>
          </div>
        </section>

        <section aria-labelledby="digest-heading" class="border-t border-stone-200">
          <div class="border-b border-stone-200 bg-stone-50/70 px-4 py-3 sm:px-5">
            <h2 id="digest-heading" class="text-base font-semibold text-stone-950"><%= t("notification_preferences.edit.digest.title") %></h2>
            <p class="mt-1 text-sm leading-5 text-stone-600"><%= t("notification_preferences.edit.digest.body") %></p>
          </div>
          <div class="grid gap-4 px-4 py-4 sm:grid-cols-3 sm:px-5">
            <div>
              <%= form.label :digest_mode, t("notification_preferences.edit.digest.mode"), class: "block text-sm font-medium text-stone-800" %>
              <%= form.select :digest_mode, NotificationPreference.digest_mode_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
            </div>
            <div>
              <%= form.label :digest_weekday, t("notification_preferences.edit.digest.weekday"), class: "block text-sm font-medium text-stone-800" %>
              <%= form.select :digest_weekday, NotificationPreference.digest_weekday_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
            </div>
            <div>
              <%= form.label :digest_time, t("notification_preferences.edit.digest.time"), class: "block text-sm font-medium text-stone-800" %>
              <%= form.time_field :digest_time, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
            </div>
          </div>
        </section>

        <section aria-labelledby="relationships-heading" class="border-t border-stone-200">
          <div class="border-b border-stone-200 bg-stone-50/70 px-4 py-3 sm:px-5">
            <h2 id="relationships-heading" class="text-base font-semibold text-stone-950"><%= t("notification_preferences.edit.relationships.title") %></h2>
            <p class="mt-1 text-sm leading-5 text-stone-600"><%= t("notification_preferences.edit.relationships.body") %></p>
          </div>
          <% if @relationship_profiles.any? %>
            <div class="divide-y divide-stone-200">
              <% @relationship_profiles.each do |profile| %>
                <div class="flex min-h-16 flex-col gap-3 px-4 py-3 sm:flex-row sm:items-center sm:justify-between sm:px-5">
                  <div class="flex min-w-0 items-center gap-3">
                    <span class="inline-flex size-9 shrink-0 items-center justify-center rounded-full bg-stone-100 text-xs font-semibold text-stone-800" aria-hidden="true"><%= profile.display_name.first(2).upcase %></span>
                    <span class="truncate text-sm font-semibold text-stone-950"><%= profile.display_name %></span>
                  </div>
                  <%= select_tag "relationship_notifications[#{profile.id}]",
                    options_for_select(
                      [[t("notification_preferences.edit.relationships.inherit"), "inherit"], [t("notification_preferences.edit.relationships.muted"), "muted"]],
                      @relationship_modes.fetch(profile.id, "inherit")
                    ),
                    aria: { label: t("notification_preferences.edit.relationships.choice", name: profile.display_name) },
                    class: "min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20 sm:w-auto" %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="px-4 py-5 text-sm leading-6 text-stone-700 sm:px-5"><%= t("notification_preferences.edit.relationships.empty") %></p>
          <% end %>
        </section>

        <div class="flex justify-end border-t border-stone-200 bg-stone-50/70 px-4 py-4 sm:px-5">
          <%= form.submit t("notification_preferences.edit.save"), class: "min-h-11 rounded-lg bg-emerald-800 px-5 py-2 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        </div>
      </div>

      <aside class="hidden xl:block" aria-labelledby="delivery-preview-heading">
        <div class="sticky top-6 rounded-xl border border-stone-200 bg-white p-5">
          <h2 id="delivery-preview-heading" class="text-base font-semibold text-stone-950"><%= t("notification_preferences.edit.preview.title") %></h2>
          <p class="mt-2 text-sm leading-6 text-stone-600"><%= t("notification_preferences.edit.preview.body") %></p>
          <ol class="relative mt-6 grid gap-6 before:absolute before:bottom-3 before:left-2 before:top-3 before:w-px before:bg-stone-300">
            <li class="relative pl-7">
              <span class="absolute left-0 top-1 size-4 rounded-full border-4 border-white bg-emerald-800 ring-1 ring-emerald-100" aria-hidden="true"></span>
              <p class="text-sm font-semibold text-stone-950"><%= t("notification_preferences.edit.preview.channels") %></p>
              <p class="mt-1 text-xs leading-5 text-stone-600"><%= t("notification_preferences.edit.preview.channels_body") %></p>
            </li>
            <li class="relative pl-7">
              <span class="absolute left-0 top-1 size-4 rounded-full border-4 border-white bg-stone-400 ring-1 ring-stone-200" aria-hidden="true"></span>
              <p class="text-sm font-semibold text-stone-950"><%= t("notification_preferences.edit.preview.quiet_hours") %></p>
              <p class="mt-1 text-xs leading-5 text-stone-600"><%= t(
                "notification_preferences.edit.preview.quiet_hours_body",
                start: @notification_preference.quiet_hours_start ? l(@notification_preference.quiet_hours_start, format: :reminder_time) : t("notification_preferences.edit.preview.not_set"),
                end: @notification_preference.quiet_hours_end ? l(@notification_preference.quiet_hours_end, format: :reminder_time) : t("notification_preferences.edit.preview.not_set")
              ) %></p>
            </li>
            <li class="relative pl-7">
              <span class="absolute left-0 top-1 size-4 rounded-full border-4 border-white bg-orange-700 ring-1 ring-orange-100" aria-hidden="true"></span>
              <p class="text-sm font-semibold text-stone-950"><%= t("notification_preferences.edit.preview.priority") %></p>
              <p class="mt-1 text-xs leading-5 text-stone-600"><%= t("notification_preferences.edit.preview.priority_body") %></p>
            </li>
            <li class="relative pl-7">
              <span class="absolute left-0 top-1 size-4 rounded-full border-4 border-white bg-stone-400 ring-1 ring-stone-200" aria-hidden="true"></span>
              <p class="text-sm font-semibold text-stone-950"><%= t("notification_preferences.edit.preview.digest") %></p>
              <p class="mt-1 text-xs leading-5 text-stone-600"><%= t("notification_preferences.digest_modes.#{@notification_preference.digest_mode}") %></p>
            </li>
          </ol>
        </div>
      </aside>
    </div>
  <% end %>
</main>
