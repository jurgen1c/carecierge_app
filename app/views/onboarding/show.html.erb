<% content_for :title, t(".title") %>

<main class="flex flex-1 flex-col gap-8 py-8">
  <header class="flex flex-col gap-5 border-b border-stone-200 pb-6 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-sm font-semibold text-emerald-800"><%= t(".kicker") %></p>
      <h1 class="mt-3 text-3xl font-semibold text-stone-950"><%= t(".heading") %></h1>
      <p class="mt-3 max-w-2xl text-base leading-7 text-stone-700"><%= t(".body") %></p>
    </div>

    <%= button_to t(".skip"), skip_onboarding_path, method: :post, class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition hover:border-stone-400 hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
  </header>

  <section aria-label="<%= t(".progress_label") %>" class="grid gap-3 rounded-xl border border-stone-200 bg-white p-4 sm:grid-cols-4">
    <% t(".steps").each_with_index do |step, index| %>
      <div class="flex items-center gap-3 rounded-lg bg-stone-50 px-3 py-2">
        <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full <%= index.zero? ? "bg-emerald-800 text-white" : "border border-stone-300 bg-white text-stone-700" %> text-sm font-semibold"><%= index + 1 %></span>
        <span class="text-sm font-medium text-stone-800"><%= step %></span>
      </div>
    <% end %>
  </section>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.3fr)_minmax(18rem,0.8fr)]">
    <section class="rounded-xl border border-stone-200 bg-white p-5">
      <h2 class="text-xl font-semibold text-stone-950"><%= t(".intro_title") %></h2>
      <p class="mt-3 text-sm leading-6 text-stone-700"><%= t(".intro_body") %></p>
      <div class="mt-6 grid gap-4">
        <div class="rounded-lg border border-stone-200 bg-stone-50 p-4">
          <h3 class="text-sm font-semibold text-stone-950"><%= t(".privacy_title") %></h3>
          <p class="mt-2 text-sm leading-6 text-stone-700"><%= t(".privacy_body") %></p>
        </div>
        <div class="rounded-lg border border-stone-200 bg-stone-50 p-4">
          <h3 class="text-sm font-semibold text-stone-950"><%= t(".return_title") %></h3>
          <p class="mt-2 text-sm leading-6 text-stone-700"><%= t(".return_body") %></p>
        </div>
      </div>
    </section>

    <section class="rounded-xl border border-stone-200 bg-white p-5">
      <% if @relationship_profile.errors.any? %>
        <div class="mb-5 rounded-lg border border-red-200 bg-red-50 p-4" role="alert">
          <h2 class="text-sm font-semibold text-red-950"><%= t(".errors_heading", count: @relationship_profile.errors.count) %></h2>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-red-900">
            <% @relationship_profile.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @relationship_profile, scope: :relationship_profile, url: onboarding_path, class: "grid gap-5" do |form| %>
        <div>
          <h2 class="text-xl font-semibold text-stone-950"><%= t(".form_title") %></h2>
          <p class="mt-2 text-sm leading-6 text-stone-700"><%= t(".form_body") %></p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <%= form.label :first_name, t(".first_name"), class: "block text-sm font-medium text-stone-800" %>
            <%= form.text_field :first_name, autocomplete: "given-name", class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
          </div>
          <div>
            <%= form.label :type, t(".relationship_type"), class: "block text-sm font-medium text-stone-800" %>
            <%= form.select :type, RelationshipProfile.type_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
          </div>
        </div>

        <div>
          <%= form.label :custom_type_label, t(".custom_type_label"), class: "block text-sm font-medium text-stone-800" %>
          <p class="mt-1 text-sm leading-6 text-stone-700"><%= t(".custom_type_hint") %></p>
          <%= form.text_field :custom_type_label, maxlength: 80, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
        </div>

        <div>
          <%= form.label :birthday, t(".birthday"), class: "block text-sm font-medium text-stone-800" %>
          <p class="mt-1 text-sm leading-6 text-stone-700"><%= t(".birthday_hint") %></p>
          <%= form.date_field :birthday, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
        </div>

        <fieldset class="grid gap-4 rounded-lg border border-stone-200 bg-stone-50 p-4">
          <legend class="text-sm font-semibold text-stone-950"><%= t(".preference_title") %></legend>
          <p class="text-sm leading-6 text-stone-700"><%= t(".preference_body") %></p>
          <%= form.fields_for :relationship_preferences, @relationship_profile.relationship_preferences.first || @relationship_profile.relationship_preferences.build do |preference_fields| %>
            <%= preference_fields.hidden_field :preference_type, value: "positive" %>
            <%= preference_fields.hidden_field :category, value: "general" %>
            <%= preference_fields.hidden_field :confidence, value: "medium" %>
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <%= preference_fields.label :key, t(".preference_key"), class: "block text-sm font-medium text-stone-800" %>
                <%= preference_fields.text_field :key, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
              </div>
              <div>
                <%= preference_fields.label :value, t(".preference_value"), class: "block text-sm font-medium text-stone-800" %>
                <%= preference_fields.text_field :value, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
              </div>
            </div>
          <% end %>
        </fieldset>

        <div class="flex flex-wrap items-center gap-3">
          <%= form.submit t(".submit"), class: "inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
          <%= button_tag t(".save_later"), type: "submit", formaction: skip_onboarding_path, formmethod: "post", class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition hover:border-stone-400 hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        </div>
      <% end %>
    </section>

    <aside class="rounded-xl border border-stone-200 bg-stone-100/80 p-5">
      <h2 class="text-base font-semibold text-stone-950"><%= t(".preview_title") %></h2>
      <p class="mt-3 text-sm leading-6 text-stone-700"><%= t(".preview_body") %></p>
      <dl class="mt-6 grid gap-4">
        <% t(".preview_items").each do |item| %>
          <div class="border-t border-stone-200 pt-4">
            <dt class="text-sm font-semibold text-stone-950"><%= item.fetch(:term, item["term"]) %></dt>
            <dd class="mt-1 text-sm leading-6 text-stone-700"><%= item.fetch(:description, item["description"]) %></dd>
          </div>
        <% end %>
      </dl>
    </aside>
  </div>
</main>
