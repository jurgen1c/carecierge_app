<%= form_with model: relationship_profile, class: "grid gap-6" do |form| %>
  <% if relationship_profile.errors.any? %>
    <section class="rounded-lg border border-red-200 bg-red-50 p-4" role="alert">
      <h2 class="text-sm font-semibold text-red-950"><%= t(".errors_heading", count: relationship_profile.errors.count) %></h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-red-900">
        <% relationship_profile.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <section class="rounded-xl border border-stone-200 bg-white p-5">
    <h2 class="text-base font-semibold text-stone-950"><%= t(".core_details") %></h2>
    <div class="mt-5 grid gap-4 md:grid-cols-2">
      <div>
        <%= form.label :first_name, t(".first_name"), class: "block text-sm font-medium text-stone-800" %>
        <%= form.text_field :first_name, autocomplete: "given-name", class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>
      <div>
        <%= form.label :last_name, t(".last_name"), class: "block text-sm font-medium text-stone-800" %>
        <%= form.text_field :last_name, autocomplete: "family-name", class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>
      <div>
        <%= form.label :preferred_name, t(".preferred_name"), class: "block text-sm font-medium text-stone-800" %>
        <%= form.text_field :preferred_name, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>
      <div>
        <%= form.label :relationship_type_name, t(".relationship_type"), class: "block text-sm font-medium text-stone-800" %>
        <%= form.text_field :relationship_type_name, list: "relationship-type-options", class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
        <datalist id="relationship-type-options">
          <% current_user.relationship_types.active.order(:name).each do |relationship_type| %>
            <option value="<%= relationship_type.name %>"></option>
          <% end %>
        </datalist>
      </div>
      <div>
        <%= form.label :pronouns, t(".pronouns"), class: "block text-sm font-medium text-stone-800" %>
        <%= form.text_field :pronouns, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>
      <div>
        <%= form.label :birthday, t(".birthday"), class: "block text-sm font-medium text-stone-800" %>
        <%= form.date_field :birthday, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>
    </div>
  </section>

  <section class="rounded-xl border border-stone-200 bg-white p-5">
    <h2 class="text-base font-semibold text-stone-950"><%= t(".contact_details") %></h2>
    <div class="mt-5 grid gap-4 md:grid-cols-2">
      <div>
        <%= form.label :email, t(".email"), class: "block text-sm font-medium text-stone-800" %>
        <%= form.email_field :email, autocomplete: "email", class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>
      <div>
        <%= form.label :phone, t(".phone"), class: "block text-sm font-medium text-stone-800" %>
        <%= form.telephone_field :phone, autocomplete: "tel", class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>
    </div>
  </section>

  <section class="rounded-xl border border-stone-200 bg-white p-5">
    <h2 class="text-base font-semibold text-stone-950"><%= t(".context_title") %></h2>
    <div class="mt-5 grid gap-4">
      <div>
        <%= form.label :notes, t(".notes"), class: "block text-sm font-medium text-stone-800" %>
        <%= form.text_area :notes, rows: 5, class: "mt-2 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>
      <div>
        <%= form.label :private_notes, t(".private_notes"), class: "block text-sm font-medium text-stone-800" %>
        <p class="mt-1 text-sm leading-6 text-stone-700"><%= t(".private_notes_hint") %></p>
        <%= form.text_area :private_notes, rows: 4, class: "mt-2 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>
      <div>
        <%= form.label :structured_preferences_text, t(".structured_preferences"), class: "block text-sm font-medium text-stone-800" %>
        <p class="mt-1 text-sm leading-6 text-stone-700"><%= t(".structured_preferences_hint") %></p>
        <%= form.text_area :structured_preferences_text, rows: 4, class: "mt-2 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>
      <div>
        <%= form.label :tag_names, t(".tag_names"), class: "block text-sm font-medium text-stone-800" %>
        <%= form.text_field :tag_names, placeholder: t(".tag_names_placeholder"), class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 placeholder:text-stone-500 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>
    </div>
  </section>

  <div class="flex flex-wrap items-center gap-3">
    <%= form.submit t(".submit"), class: "inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <%= link_to t(".cancel"), relationship_profiles_path, class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
  </div>
<% end %>
