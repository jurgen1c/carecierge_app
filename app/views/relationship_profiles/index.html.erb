<% content_for :title, t(".title") %>

<main class="flex flex-1 flex-col gap-8 py-8">
  <header class="flex flex-col gap-5 border-b border-stone-200 pb-6 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-sm font-semibold text-emerald-800"><%= t(".kicker") %></p>
      <h1 class="mt-3 text-3xl font-semibold text-stone-950"><%= t(".heading") %></h1>
      <p class="mt-3 max-w-2xl text-base leading-7 text-stone-700"><%= t(".body") %></p>
    </div>

    <%= link_to t(".new_profile"), new_relationship_profile_path, class: "inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
  </header>

  <section aria-labelledby="relationship-profile-filters" class="rounded-xl border border-stone-200 bg-white p-5">
    <h2 id="relationship-profile-filters" class="text-base font-semibold text-stone-950"><%= t(".filters_title") %></h2>
    <%= form_with url: relationship_profiles_path, method: :get, class: "mt-4 grid gap-4 md:grid-cols-[1fr_auto_auto_auto_auto]" do %>
      <div>
        <%= label_tag "q[#{RelationshipProfile::SearchQuery::SEARCH_PREDICATE}]", t(".search_label"), class: "block text-sm font-medium text-stone-800" %>
        <%= text_field_tag "q[#{RelationshipProfile::SearchQuery::SEARCH_PREDICATE}]", @search_query, placeholder: t(".search_placeholder"), class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 placeholder:text-stone-500 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>

      <div>
        <%= label_tag :status, t(".status_label"), class: "block text-sm font-medium text-stone-800" %>
        <%= select_tag :status, options_for_select([[t(".statuses.active"), "active"], [t(".statuses.archived"), "archived"], [t(".statuses.all"), "all"]], @status), class: "mt-2 min-h-11 rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>

      <div>
        <%= label_tag :tag_id, t(".tag_label"), class: "block text-sm font-medium text-stone-800" %>
        <%= select_tag :tag_id, options_from_collection_for_select(@relationship_tags, :id, :name, @tag_id), include_blank: t(".all_tags"), class: "mt-2 min-h-11 rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>

      <div>
        <%= label_tag :group_id, t(".group_label"), class: "block text-sm font-medium text-stone-800" %>
        <%= select_tag :group_id, options_from_collection_for_select(@relationship_groups, :id, :name, @group_id), include_blank: t(".all_groups"), class: "mt-2 min-h-11 rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
      </div>

      <div class="flex items-end">
        <%= submit_tag t(".apply_filters"), class: "inline-flex min-h-11 w-full items-center justify-center rounded-lg border border-stone-300 bg-stone-50 px-5 py-3 text-sm font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
      </div>
    <% end %>
  </section>

  <% if @relationship_profiles.any? %>
    <section aria-label="<%= t(".profiles_label") %>" class="grid gap-4 md:grid-cols-2">
      <% @relationship_profiles.each do |profile| %>
        <article class="rounded-xl border border-stone-200 bg-white p-5">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <h2 class="text-lg font-semibold text-stone-950"><%= link_to profile.display_name, relationship_profile_path(profile), class: "rounded-sm hover:text-emerald-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %></h2>
              <p class="mt-1 text-sm text-stone-700"><%= profile.relationship_type_label %></p>
            </div>

            <% if profile.archived? %>
              <span class="inline-flex w-fit items-center rounded-full border border-stone-300 px-3 py-1 text-xs font-semibold text-stone-700"><%= t(".archived") %></span>
            <% end %>
          </div>

          <% notes_preview = profile.public_notes_preview %>
          <% if notes_preview.present? %>
            <p class="mt-4 text-sm leading-6 text-stone-700"><%= truncate(notes_preview, length: 140) %></p>
          <% end %>

          <% if profile.relationship_tags.any? %>
            <div class="mt-4 flex flex-wrap gap-2">
              <% profile.relationship_tags.each do |tag| %>
                <span class="rounded-full bg-stone-100 px-3 py-1 text-xs font-medium text-stone-700"><%= tag.name %></span>
              <% end %>
            </div>
          <% end %>

          <% if profile.relationship_groups.any? %>
            <div class="mt-3 flex flex-wrap gap-2">
              <% profile.relationship_groups.each do |group| %>
                <span class="rounded-full border border-emerald-100 bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-900"><%= group.name %></span>
              <% end %>
            </div>
          <% end %>
        </article>
      <% end %>
    </section>
  <% else %>
    <section class="rounded-xl border border-dashed border-stone-300 bg-white p-8">
      <h2 class="text-lg font-semibold text-stone-950"><%= t(".empty_title") %></h2>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-stone-700"><%= t(".empty_body") %></p>
      <%= link_to t(".new_profile"), new_relationship_profile_path, class: "mt-5 inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    </section>
  <% end %>
</main>
