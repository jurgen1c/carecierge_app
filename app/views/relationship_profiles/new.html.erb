<% content_for :title, t(".title") %>

<main class="flex flex-1 flex-col gap-8 py-8">
  <header class="border-b border-stone-200 pb-6">
    <p class="text-sm font-semibold text-emerald-800"><%= t(".kicker") %></p>
    <h1 class="mt-3 text-3xl font-semibold text-stone-950"><%= t(".heading") %></h1>
    <p class="mt-3 max-w-2xl text-base leading-7 text-stone-700"><%= t(".body") %></p>
  </header>

  <%= render "form", relationship_profile: @relationship_profile, relationship_profile_form: @relationship_profile_form %>
</main>
