<% content_for :title, @relationship_profile.display_name %>

<main class="flex flex-1 flex-col gap-8 py-8">
  <header class="flex flex-col gap-5 border-b border-stone-200 pb-6 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-sm font-semibold text-emerald-800"><%= @relationship_profile.relationship_type_label %></p>
      <h1 class="mt-3 text-3xl font-semibold text-stone-950"><%= @relationship_profile.display_name %></h1>
      <% if @relationship_profile.full_name != @relationship_profile.display_name %>
        <p class="mt-2 text-sm text-stone-700"><%= @relationship_profile.full_name %></p>
      <% end %>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= link_to t(".edit"), edit_relationship_profile_path(@relationship_profile), class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
      <% unless @relationship_profile.archived? %>
        <%= button_to t(".archive"), archive_relationship_profile_path(@relationship_profile), method: :patch, class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
      <% end %>
    </div>
  </header>

  <%= render "important_dates/section", relationship_profile: @relationship_profile %>
  <%= render "gifts/section", relationship_profile: @relationship_profile %>
  <%= render "desires/section", relationship_profile: @relationship_profile %>

  <section class="grid gap-5 lg:grid-cols-[1.3fr_0.7fr]">
    <article class="rounded-xl border border-stone-200 bg-white p-5">
      <h2 class="text-base font-semibold text-stone-950"><%= t(".details_title") %></h2>
      <dl class="mt-4 grid gap-4 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-medium text-stone-700"><%= t(".birthday") %></dt>
          <dd class="mt-1 text-sm text-stone-950"><%= @relationship_profile.birthday || t(".not_provided") %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-stone-700"><%= t(".pronouns") %></dt>
          <dd class="mt-1 text-sm text-stone-950"><%= @relationship_profile.pronouns.presence || t(".not_provided") %></dd>
        </div>
      </dl>

      <div class="mt-6">
        <h3 class="text-sm font-semibold text-stone-950"><%= t(".notes") %></h3>
        <% if @relationship_profile.public_notes.any? %>
          <div class="mt-2 grid gap-3">
            <% @relationship_profile.public_notes.each do |note| %>
              <div class="lexxy-content text-sm leading-6 text-stone-700"><%= note.body %></div>
            <% end %>
          </div>
        <% else %>
          <p class="mt-2 text-sm leading-6 text-stone-700"><%= t(".not_provided") %></p>
        <% end %>
      </div>

      <div class="mt-6 rounded-lg border border-stone-200 bg-stone-50 p-4">
        <h3 class="text-sm font-semibold text-stone-950"><%= t(".private_notes") %></h3>
        <% if @relationship_profile.private_notes.any? %>
          <div class="mt-2 grid gap-3">
            <% @relationship_profile.private_notes.each do |note| %>
              <div class="lexxy-content text-sm leading-6 text-stone-700"><%= note.body %></div>
            <% end %>
          </div>
        <% else %>
          <p class="mt-2 text-sm leading-6 text-stone-700"><%= t(".not_provided") %></p>
        <% end %>
      </div>
    </article>

    <aside class="flex flex-col gap-5">
      <%= render "important_dates/upcoming", relationship_profile: @relationship_profile %>

      <section class="rounded-xl border border-stone-200 bg-white p-5">
        <h2 class="text-base font-semibold text-stone-950"><%= t(".contact_title") %></h2>
        <% if @relationship_profile.contact_methods.any? %>
          <dl class="mt-4 space-y-3">
            <% @relationship_profile.contact_methods.each do |method| %>
              <div>
                <dt class="text-sm font-medium text-stone-700"><%= t(method.kind, scope: "relationship_profiles.show.contact_kinds") %></dt>
                <dd class="mt-1 break-words text-sm text-stone-950"><%= method.value %></dd>
              </div>
            <% end %>
          </dl>
        <% else %>
          <p class="mt-3 text-sm leading-6 text-stone-700"><%= t(".not_provided") %></p>
        <% end %>
      </section>

      <section class="rounded-xl border border-stone-200 bg-white p-5">
        <h2 class="text-base font-semibold text-stone-950"><%= t(".preferences_title") %></h2>
        <% if @relationship_profile.relationship_preferences.any? %>
          <div class="mt-4 space-y-4">
            <% @relationship_profile.relationship_preferences.sort_by { |preference| [ preference.category_label, preference.key.downcase ] }.each do |preference| %>
              <article class="rounded-lg border border-stone-200 bg-stone-50 p-4">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-900"><%= preference.preference_type_label %></span>
                  <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-stone-700"><%= preference.category_label %></span>
                </div>
                <h3 class="mt-3 text-sm font-semibold text-stone-950"><%= preference.key %></h3>
                <p class="mt-1 text-sm leading-6 text-stone-700"><%= preference.value %></p>
                <dl class="mt-3 grid gap-2 text-xs text-stone-700">
                  <div>
                    <dt class="font-semibold text-stone-800"><%= t(".preference_confidence") %></dt>
                    <dd class="mt-1"><%= preference.confidence_label %></dd>
                  </div>
                  <% if preference.learned_on.present? %>
                    <div>
                      <dt class="font-semibold text-stone-800"><%= t(".preference_learned_on") %></dt>
                      <dd class="mt-1"><%= l(preference.learned_on, format: :relationship_preference_learned_on) %></dd>
                    </div>
                  <% end %>
                  <% if preference.source_notes.present? %>
                    <div>
                      <dt class="font-semibold text-stone-800"><%= t(".preference_source_notes") %></dt>
                      <dd class="mt-1 leading-5"><%= preference.source_notes %></dd>
                    </div>
                  <% end %>
                </dl>
              </article>
            <% end %>
          </div>
        <% else %>
          <p class="mt-3 text-sm leading-6 text-stone-700"><%= t(".not_provided") %></p>
        <% end %>
      </section>

      <section class="rounded-xl border border-stone-200 bg-white p-5">
        <h2 class="text-base font-semibold text-stone-950"><%= t(".field_values_title") %></h2>
        <% visible_relationship_field_values = @relationship_profile.visible_relationship_field_values %>
        <% if visible_relationship_field_values.any? %>
          <dl class="mt-4 space-y-3">
            <% visible_relationship_field_values.each do |field_value| %>
              <div>
                <dt class="text-sm font-medium text-stone-700"><%= field_value.display_label %></dt>
                <dd class="mt-1 whitespace-pre-line text-sm text-stone-950"><%= field_value.value %></dd>
              </div>
            <% end %>
          </dl>
        <% else %>
          <p class="mt-3 text-sm leading-6 text-stone-700"><%= t(".not_provided") %></p>
        <% end %>
      </section>

      <section class="rounded-xl border border-stone-200 bg-white p-5">
        <h2 class="text-base font-semibold text-stone-950"><%= t(".tags_title") %></h2>
        <% if @relationship_profile.relationship_tags.any? %>
          <div class="mt-4 flex flex-wrap gap-2">
            <% @relationship_profile.relationship_tags.each do |tag| %>
              <span class="rounded-full bg-stone-100 px-3 py-1 text-xs font-medium text-stone-700"><%= tag.name %></span>
            <% end %>
          </div>
        <% else %>
          <p class="mt-3 text-sm leading-6 text-stone-700"><%= t(".not_provided") %></p>
        <% end %>
      </section>

      <section class="rounded-xl border border-stone-200 bg-white p-5">
        <h2 class="text-base font-semibold text-stone-950"><%= t(".groups_title") %></h2>
        <% if @relationship_profile.relationship_groups.any? %>
          <div class="mt-4 flex flex-wrap gap-2">
            <% @relationship_profile.relationship_groups.each do |group| %>
              <span class="rounded-full border border-emerald-100 bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-900"><%= group.name %></span>
            <% end %>
          </div>
        <% else %>
          <p class="mt-3 text-sm leading-6 text-stone-700"><%= t(".not_provided") %></p>
        <% end %>
      </section>
    </aside>
  </section>

  <div class="flex flex-wrap items-center justify-between gap-3 border-t border-stone-200 pt-5">
    <%= link_to t(".back"), relationship_profiles_path, class: "text-sm font-semibold text-emerald-800 hover:text-emerald-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <%= button_to t(".delete"), relationship_profile_path(@relationship_profile), method: :delete, form: { data: { turbo_confirm: t(".delete_confirm") } }, class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-red-300 bg-white px-5 py-3 text-sm font-semibold text-red-800 transition hover:bg-red-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-700" %>
  </div>
</main>
