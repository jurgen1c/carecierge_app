<% if commitments.any? %>
  <section class="border-b border-stone-200 py-5" aria-labelledby="overdue-commitments-title">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <h2 id="overdue-commitments-title" class="text-base font-semibold text-stone-950"><%= t("reminders.commitments.title") %></h2>
      <span class="rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-red-800"><%= t("reminders.commitments.count", count: commitments.size) %></span>
    </div>
    <div class="mt-3 divide-y divide-stone-200">
      <% commitments.each do |commitment| %>
        <article class="flex flex-col gap-3 py-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h3 class="text-sm font-semibold text-stone-950"><%= commitment.title %></h3>
            <p class="mt-1 text-sm text-red-700"><%= t("reminders.commitments.overdue_since", date: l(commitment.due_on, format: :commitment_due_on)) %></p>
            <p class="mt-1 text-xs text-stone-600"><%= commitment.relationship_profile.display_name %> · <%= t("commitments.item.reminder_count", count: commitment.reminders.size) %></p>
          </div>
          <%= link_to t("reminders.commitments.view"), relationship_profile_path(commitment.relationship_profile, anchor: dom_id(commitment, :row)), data: { turbo_frame: "_top" }, class: "inline-flex min-h-11 w-fit items-center rounded-lg border border-stone-300 bg-white px-4 py-2 text-sm font-semibold text-stone-900 hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        </article>
      <% end %>
    </div>
  </section>
<% end %>
