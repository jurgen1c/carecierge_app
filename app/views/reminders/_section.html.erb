<section class="rounded-2xl border border-stone-200 bg-white p-5 shadow-sm shadow-stone-200/40">
  <div class="flex flex-col gap-4 border-b border-stone-200 pb-5 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-sm font-semibold text-emerald-800"><%= t("reminders.section.kicker") %></p>
      <h2 class="mt-2 text-xl font-semibold text-stone-950"><%= t("reminders.section.title") %></h2>
      <p class="mt-2 max-w-3xl text-sm leading-6 text-stone-700"><%= t("reminders.section.body") %></p>
    </div>
    <%= link_to t("reminders.section.view_all"), reminders_path(relationship_profile_id: relationship_profile.id), class: "inline-flex min-h-11 w-fit items-center rounded-lg bg-emerald-800 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-900" %>
  </div>
  <% reminders = relationship_profile.reminders.select(&:active?).sort_by { |reminder| [reminder.effective_delivery_at, reminder.title.downcase] }.first(5) %>
  <% if reminders.any? %>
    <div class="mt-3"><% reminders.each do |reminder| %><%= component "reminder_row", reminder:, compact: true %><% end %></div>
  <% else %>
    <p class="mt-5 text-sm leading-6 text-stone-700"><%= t("reminders.section.empty") %></p>
  <% end %>
</section>
