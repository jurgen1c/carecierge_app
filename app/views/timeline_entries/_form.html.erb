<% form_url = timeline_entry.persisted? ? relationship_profile_timeline_entry_path(relationship_profile, timeline_entry, timeline_type:) : relationship_profile_timeline_entries_path(relationship_profile, timeline_type:) %>

<%= form_with model: timeline_entry, url: form_url, method: timeline_entry.persisted? ? :patch : :post, class: "rounded-xl border border-stone-200 bg-white p-4" do |form| %>
  <div>
    <h3 class="text-base font-semibold text-stone-950"><%= timeline_entry.persisted? ? t("timeline_entries.form.edit_title") : t("timeline_entries.form.new_title") %></h3>
    <p class="mt-1 text-sm leading-6 text-stone-700"><%= t("timeline_entries.form.body") %></p>
  </div>

  <% if timeline_entry.errors.any? %>
    <div class="mt-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-950">
      <p class="font-semibold"><%= t("timeline_entries.form.errors_heading", count: timeline_entry.errors.count) %></p>
      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% timeline_entry.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mt-4 grid gap-4 sm:grid-cols-2">
    <div class="sm:col-span-2">
      <%= form.label :title, t("timeline_entries.form.title"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.text_field :title, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20", placeholder: t("timeline_entries.form.title_placeholder") %>
    </div>

    <div>
      <%= form.label :entry_type, t("timeline_entries.form.entry_type"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.select :entry_type, TimelineEntry.entry_type_options, {}, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>

    <div>
      <%= form.label :occurred_at, t("timeline_entries.form.occurred_at"), class: "block text-sm font-medium text-stone-800" %>
      <%= form.datetime_local_field :occurred_at, class: "mt-2 min-h-11 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20" %>
    </div>
  </div>

  <div class="mt-4">
    <%= form.label :body, t("timeline_entries.form.body_label"), class: "block text-sm font-medium text-stone-800" %>
    <%= form.text_area :body, rows: 3, class: "mt-2 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-base text-stone-950 focus:border-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-700/20", placeholder: t("timeline_entries.form.body_placeholder") %>
  </div>

  <div class="mt-4 flex flex-wrap items-center gap-3">
    <%= form.submit timeline_entry.persisted? ? t("timeline_entries.form.update") : t("timeline_entries.form.create"), class: "inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <% if timeline_entry.persisted? %>
      <%= link_to t("timeline_entries.form.cancel"), relationship_profile_path(relationship_profile, timeline_type:, anchor: dom_id(timeline_entry, :row)), data: { turbo_frame: "_top" }, class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
    <% end %>
  </div>
<% end %>
