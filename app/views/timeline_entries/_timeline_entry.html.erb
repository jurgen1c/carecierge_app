<%= turbo_frame_tag dom_id(timeline_entry) do %>
  <article id="<%= dom_id(timeline_entry, :row) %>" data-timeline-entry-row="true" class="grid gap-3 border-b border-stone-200 py-4 last:border-b-0 sm:grid-cols-[7rem_minmax(0,1fr)_auto]">
    <div class="text-sm text-stone-700">
      <time datetime="<%= timeline_entry.occurred_at.iso8601 %>" class="font-semibold text-stone-950"><%= l(timeline_entry.occurred_at, format: :timeline_entry_day) %></time>
      <p class="mt-1 text-xs font-medium text-stone-600"><%= l(timeline_entry.occurred_at, format: :timeline_entry_time) %></p>
    </div>

    <div class="relative pl-6">
      <span class="absolute left-0 top-1.5 size-3 rounded-full border-2 border-white bg-emerald-800 ring-2 ring-emerald-100" aria-hidden="true"></span>
      <div class="flex flex-wrap items-center gap-2">
        <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-900"><%= timeline_entry.entry_type_label %></span>
        <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-stone-700"><%= timeline_entry.origin_label %></span>
        <% if timeline_entry.source_record_label.present? %>
          <span class="rounded-full border border-stone-200 bg-white px-3 py-1 text-xs font-medium text-stone-700"><%= timeline_entry.source_record_label %></span>
        <% end %>
      </div>

      <h4 class="mt-3 text-base font-semibold text-stone-950"><%= timeline_entry.title %></h4>
      <% if timeline_entry.body.present? %>
        <p class="mt-2 text-sm leading-6 text-stone-700"><%= timeline_entry.body %></p>
      <% end %>
    </div>

    <% if policy(timeline_entry).update? || policy(timeline_entry).destroy? %>
      <div class="flex shrink-0 flex-wrap gap-2 sm:justify-end">
        <% if policy(timeline_entry).update? %>
          <%= link_to t("timeline_entries.item.edit"), edit_relationship_profile_timeline_entry_path(relationship_profile, timeline_entry, timeline_type: selected_type), class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-stone-300 bg-white px-4 py-2 text-sm font-semibold text-stone-900 transition hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        <% end %>
        <% if policy(timeline_entry).destroy? %>
          <%= button_to t("timeline_entries.item.delete"), relationship_profile_timeline_entry_path(relationship_profile, timeline_entry, timeline_type: selected_type), method: :delete, form: { data: { turbo_confirm: t("timeline_entries.item.delete_confirm") } }, class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-red-300 bg-white px-4 py-2 text-sm font-semibold text-red-800 transition hover:bg-red-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-700" %>
        <% end %>
      </div>
    <% end %>
  </article>
<% end %>
