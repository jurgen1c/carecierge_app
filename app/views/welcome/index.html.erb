<% content_for :title, t(".title") %>

<main class="flex flex-1 items-center justify-center py-12">
  <section class="grid w-full gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold text-emerald-800"><%= t(".kicker") %></p>
      <h1 class="mt-4 text-4xl font-semibold tracking-normal text-stone-950 sm:text-5xl"><%= t(".heading") %></h1>
      <p class="mt-5 max-w-xl text-lg leading-8 text-stone-700"><%= t(".body") %></p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <%= link_to t(".create_account"), new_user_registration_path, class: "inline-flex min-h-11 items-center justify-center rounded-lg bg-emerald-800 px-5 py-3 text-sm font-semibold text-white transition hover:bg-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
        <%= link_to t(".sign_in"), new_user_session_path, class: "inline-flex min-h-11 items-center justify-center rounded-lg border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition hover:border-stone-400 hover:bg-stone-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700" %>
      </div>
    </div>

    <div class="rounded-xl border border-stone-200 bg-white p-6">
      <h2 class="text-base font-semibold text-stone-950"><%= t(".panel_title") %></h2>
      <ul class="mt-5 space-y-4 text-sm leading-6 text-stone-700">
        <li class="rounded-lg bg-stone-50 p-4"><%= t(".private_memory") %></li>
        <li class="rounded-lg bg-stone-50 p-4"><%= t(".clear_guidance") %></li>
        <li class="rounded-lg bg-stone-50 p-4"><%= t(".onboarding_ready") %></li>
      </ul>
    </div>
  </section>
</main>
